---
import PageLayout from '../../layouts/PageLayout.astro';
import CasinoTopList from '../../components/casino/CasinoTopList.astro';
import FaqSection from '../../components/content/FaqSection.astro';
import WaveDecoration from '../../components/ui/WaveDecoration.astro';
import Button from '../../components/ui/Button.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import ArticleImage from '../../components/ui/ArticleImage.astro';
import ImageGallery from '../../components/ui/ImageGallery.astro';
import { ALL_LOCALES, type Locale } from '../../i18n/config';
import { t, getPagePath } from '../../i18n/utils';
import { websiteSchema, articleSchema, faqSchema } from '../../lib/seo/schema-generators';
import { getCasinosForLocale } from '../../data/casinos';

export function getStaticPaths() {
  return ALL_LOCALES.map(locale => ({
    params: { lang: locale },
    props: { locale },
  }));
}

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = t(locale, 'hero.title');
const subtitle = t(locale, 'hero.subtitle');
const playNowText = t(locale, 'hero.playNow');
const playFreeText = t(locale, 'hero.playFree');

const casinoResults = getCasinosForLocale(locale);

// FAQs about Big Bass Crash
const faqs = [
  { q: t(locale, 'faq.home.q1'), a: t(locale, 'faq.home.a1') },
  { q: t(locale, 'faq.home.q2'), a: t(locale, 'faq.home.a2') },
  { q: t(locale, 'faq.home.q3'), a: t(locale, 'faq.home.a3') },
  { q: t(locale, 'faq.home.q4'), a: t(locale, 'faq.home.a4') },
  { q: t(locale, 'faq.home.q5'), a: t(locale, 'faq.home.a5') },
];

const pageUrl = getPagePath('home', locale);
const buildDate = new Date().toISOString().split('T')[0];
const authorName = 'BigBassCrashGame Editorial';

const schemas = [
  websiteSchema(),
  articleSchema({
    title,
    description: subtitle,
    url: pageUrl,
    image: '/images/og/home.jpg',
    datePublished: '2025-01-15',
    dateModified: buildDate,
    locale,
    authorName,
  }),
  faqSchema(faqs),
].filter(Boolean) as object[];

const breadcrumbs = [
  { label: t(locale, 'nav.home') },
];
---

<PageLayout
  locale={locale}
  pageId="home"
  title={title}
  description={subtitle}
  ogImage="/images/og/home.jpg"
  canonicalPath={pageUrl}
  schema={schemas}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-ocean-950 via-ocean-900 to-ocean-800">
    <!-- Background decoration -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-accent-500/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-water-500/5 rounded-full blur-3xl"></div>
      <!-- Subtle fish pattern overlay -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('/images/game/pattern-fish.svg'); background-size: 200px;"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 lg:py-32">
      <div class="text-center max-w-3xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent-500/10 border border-accent-500/20 mb-6">
          <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
          <span class="text-sm text-accent-400 font-medium">Pragmatic Play</span>
        </div>

        <!-- H1 -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
          <span class="bg-gradient-to-r from-white via-gray-100 to-gray-300 bg-clip-text text-transparent">
            {title}
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg sm:text-xl text-gray-300 leading-relaxed mb-10 max-w-2xl mx-auto">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button
            href={`/go/1xbet?from=home&lang=${locale}`}
            variant="primary"
            size="xl"
            target="_blank"
            rel="noopener noreferrer nofollow"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
            {playNowText}
          </Button>

          <Button
            href={getPagePath('play-free', locale)}
            variant="outline"
            size="xl"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {playFreeText}
          </Button>
        </div>

        <!-- Hero Image -->
        <div class="mt-10 max-w-2xl mx-auto">
          <picture>
            <source srcset="/images/game/beautiful-gameplay-1.webp" type="image/webp" />
            <img
              src="/images/game/beautiful-gameplay-1.jpg"
              alt={t(locale, 'alt.hero.main')}
              width="800"
              height="450"
              loading="eager"
              decoding="async"
              class="w-full rounded-2xl shadow-2xl border border-ocean-600/30"
            />
          </picture>
        </div>

        <!-- Trust indicators -->
        <div class="flex flex-wrap items-center justify-center gap-6 mt-10 text-sm text-gray-400">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>{t(locale, 'trust.licensed')}</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" />
            </svg>
            <span>{t(locale, 'trust.instant')}</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm4.707 3.707a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L8.414 9H10a3 3 0 013 3v1a1 1 0 102 0v-1a5 5 0 00-5-5H8.414l1.293-1.293z" clip-rule="evenodd" />
            </svg>
            <span>{t(locale, 'trust.bonuses')}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave transition -->
    <WaveDecoration position="bottom" color="text-ocean-900" />
  </section>

  <!-- Main Content -->
  <div class="bg-ocean-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbs} locale={locale} />

      <!-- Casino Top List -->
      <CasinoTopList
        casinos={casinoResults}
        locale={locale}
        pageSlug="home"
        variant="full"
        title={t(locale, 'casino.topCasinos')}
        maxItems={3}
      />

      <!-- Wave separator -->
      <WaveDecoration position="top" color="text-ocean-800" />
    </div>
  </div>

  <!-- Article Section -->
  <section class="bg-ocean-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <p class="text-sm text-gray-400 mb-6">
        By {authorName} · Updated {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </p>

      <article class="prose prose-invert prose-lg max-w-none prose-headings:text-white prose-headings:font-bold prose-p:text-gray-300 prose-a:text-accent-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-white">
        <h2>{t(locale, 'article.home.whatIs.title')}</h2>
        <p set:html={t(locale, 'article.home.whatIs.p1')} />
        <p set:html={t(locale, 'article.home.whatIs.p2')} />

        <ArticleImage src="/images/game/beautiful-gameplay-2.jpg" alt={t(locale, 'alt.home.gameplay')} width={800} height={450} />

        <h2>{t(locale, 'article.home.features.title')}</h2>
        <ul>
          <li set:html={t(locale, 'article.home.features.fishing')} />
          <li set:html={t(locale, 'article.home.features.autoCashout')} />
          <li set:html={t(locale, 'article.home.features.multiBet')} />
          <li set:html={t(locale, 'article.home.features.liveStats')} />
          <li set:html={t(locale, 'article.home.features.mobile')} />
        </ul>

        <ArticleImage src="/images/game/beautiful-gameplay-3.jpg" alt={t(locale, 'alt.home.features')} width={800} height={450} />

        <h2>{t(locale, 'article.home.howToWin.title')}</h2>
        <p set:html={t(locale, 'article.home.howToWin.p1')} />
        <p set:html={t(locale, 'article.home.howToWin.p2')} />

        <h2>{t(locale, 'article.home.howToPlay.title')}</h2>
        <p set:html={t(locale, 'article.home.howToPlay.p1')} />
        <p set:html={t(locale, 'article.home.howToPlay.p2')} />

        <ArticleImage src="/images/game/theme-1.jpg" alt={t(locale, 'alt.home.howToPlay')} width={800} height={450} />

        <h2>{t(locale, 'article.home.rtp.title')}</h2>
        <p set:html={t(locale, 'article.home.rtp.p1')} />
        <p set:html={t(locale, 'article.home.rtp.p2')} />

        <table>
          <thead>
            <tr>
              <th>{t(locale, 'table.specs.gameName')}</th>
              <th>Big Bass Crash</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>{t(locale, 'table.specs.provider')}</td><td>Pragmatic Play</td></tr>
            <tr><td>{t(locale, 'table.specs.rtp')}</td><td>96.47%</td></tr>
            <tr><td>{t(locale, 'table.specs.volatility')}</td><td>{t(locale, 'table.specs.volatilityHigh')}</td></tr>
            <tr><td>{t(locale, 'table.specs.maxMultiplier')}</td><td>1,000x</td></tr>
            <tr><td>{t(locale, 'table.specs.minBet')}</td><td>$0.10</td></tr>
            <tr><td>{t(locale, 'table.specs.maxBet')}</td><td>$100</td></tr>
            <tr><td>{t(locale, 'table.specs.gameType')}</td><td>{t(locale, 'table.specs.crashGame')}</td></tr>
            <tr><td>{t(locale, 'table.specs.platforms')}</td><td>{t(locale, 'table.specs.platformsList')}</td></tr>
            <tr><td>{t(locale, 'table.specs.releaseYear')}</td><td>2024</td></tr>
          </tbody>
        </table>

        <ArticleImage src="/images/game/gameplay-1.png" alt={t(locale, 'alt.home.rtp')} width={800} height={450} />
      </article>
    </div>
  </section>

  <!-- Game Screenshots Gallery -->
  <ImageGallery locale={locale} />

  <!-- FAQ & Comments -->
  <section class="bg-ocean-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Wave decoration -->
      <WaveDecoration position="top" color="text-ocean-900" />

      <!-- FAQ -->
      <FaqSection faqs={faqs} locale={locale} />
    </div>
  </section>
</PageLayout>
