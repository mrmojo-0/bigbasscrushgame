---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Content Management" currentPage="content">
  <!-- Controls Row -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div>
      <label class="block text-sm text-gray-400 mb-1.5">Language</label>
      <select id="lang-select" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none">
        <option value="en">English</option>
        <option value="ru">Russian - Русский</option>
        <option value="de">German - Deutsch</option>
        <option value="fr">French - Français</option>
        <option value="es">Spanish - Español</option>
        <option value="pt">Portuguese - Português</option>
        <option value="it">Italian - Italiano</option>
        <option value="nl">Dutch - Nederlands</option>
        <option value="pl">Polish - Polski</option>
        <option value="cs">Czech - Čeština</option>
        <option value="sk">Slovak - Slovenčina</option>
        <option value="hu">Hungarian - Magyar</option>
        <option value="ro">Romanian - Română</option>
        <option value="bg">Bulgarian - Български</option>
        <option value="hr">Croatian - Hrvatski</option>
        <option value="sl">Slovenian - Slovenščina</option>
        <option value="sr">Serbian - Српски</option>
        <option value="uk">Ukrainian - Українська</option>
        <option value="tr">Turkish - Türkçe</option>
        <option value="el">Greek - Ελληνικά</option>
        <option value="ar">Arabic - العربية</option>
        <option value="he">Hebrew - עברית</option>
        <option value="hi">Hindi - हिन्दी</option>
        <option value="bn">Bengali - বাংলা</option>
        <option value="ja">Japanese - 日本語</option>
        <option value="ko">Korean - 한국어</option>
        <option value="zh">Chinese - 中文</option>
        <option value="th">Thai - ไทย</option>
        <option value="vi">Vietnamese - Tiếng Việt</option>
        <option value="id">Indonesian - Bahasa Indonesia</option>
        <option value="ms">Malay - Bahasa Melayu</option>
        <option value="fil">Filipino</option>
        <option value="sv">Swedish - Svenska</option>
        <option value="no">Norwegian - Norsk</option>
        <option value="da">Danish - Dansk</option>
        <option value="fi">Finnish - Suomi</option>
        <option value="et">Estonian - Eesti</option>
        <option value="lv">Latvian - Latviešu</option>
        <option value="lt">Lithuanian - Lietuvių</option>
        <option value="ka">Georgian - ქართული</option>
      </select>
    </div>

    <div>
      <label class="block text-sm text-gray-400 mb-1.5">Page</label>
      <select id="page-select" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none">
        <option value="home">Home</option>
        <option value="play-free">Play Free</option>
        <option value="where-to-play">Where to Play</option>
        <option value="review">Review</option>
      </select>
    </div>

    <div class="flex items-end gap-2">
      <button id="btn-load" class="flex-1 bg-ocean-700 hover:bg-ocean-600 border border-ocean-600/30 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
        Load Content
      </button>
      <button id="btn-generate" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
        Generate with AI
      </button>
    </div>
  </div>

  <!-- Status Bar -->
  <div id="status-bar" class="hidden mb-4 px-4 py-3 rounded-lg text-sm"></div>

  <!-- Meta Fields -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-5 mb-6">
    <h2 class="text-sm font-semibold text-gray-300 mb-4 uppercase tracking-wide">SEO Meta</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm text-gray-400 mb-1.5">Meta Title</label>
        <input type="text" id="meta-title" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="SEO page title..." />
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1.5">Meta Description</label>
        <input type="text" id="meta-description" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="SEO meta description..." />
      </div>
    </div>
  </div>

  <!-- Split Editor / Preview -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Editor -->
    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl overflow-hidden">
      <div class="px-4 py-3 border-b border-ocean-600/20 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wide">Markdown Editor</h2>
        <span class="text-xs text-gray-500" id="char-count">0 chars</span>
      </div>
      <textarea
        id="content-editor"
        class="w-full h-96 bg-ocean-900 px-4 py-3 text-white text-sm font-mono resize-y outline-none border-none"
        placeholder="Enter Markdown content here..."
      ></textarea>
    </div>

    <!-- Preview -->
    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl overflow-hidden">
      <div class="px-4 py-3 border-b border-ocean-600/20">
        <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wide">Preview</h2>
      </div>
      <div id="content-preview" class="px-4 py-3 text-sm text-gray-300 prose prose-invert prose-sm max-w-none h-96 overflow-y-auto">
        <p class="text-gray-500 italic">Content preview will appear here...</p>
      </div>
    </div>
  </div>

  <!-- FAQ Editor -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wide">FAQ Section</h2>
      <button id="btn-add-faq" class="text-accent-400 hover:text-accent-300 text-sm font-medium transition-colors">
        + Add FAQ Pair
      </button>
    </div>
    <div id="faq-container" class="space-y-4">
      <p class="text-gray-500 text-sm italic">No FAQ items. Click "Add FAQ Pair" to create one.</p>
    </div>
  </div>

  <!-- Save Button -->
  <div class="flex justify-end gap-3">
    <button id="btn-save" class="bg-accent-500 hover:bg-accent-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium transition-colors">
      Save Content
    </button>
  </div>
</AdminLayout>

<script>
  let currentContentId: number | null = null;
  let faqItems: { q: string; a: string }[] = [];

  // Show status
  function showStatus(msg: string, type: 'success' | 'error' | 'info' = 'info') {
    const bar = document.getElementById('status-bar')!;
    bar.classList.remove('hidden', 'bg-accent-500/10', 'text-accent-400', 'border-accent-500/30',
      'bg-crash-red/10', 'text-crash-red', 'border-crash-red/30',
      'bg-blue-500/10', 'text-blue-400', 'border-blue-500/30');

    if (type === 'success') {
      bar.className = 'mb-4 px-4 py-3 rounded-lg text-sm bg-accent-500/10 text-accent-400 border border-accent-500/30';
    } else if (type === 'error') {
      bar.className = 'mb-4 px-4 py-3 rounded-lg text-sm bg-crash-red/10 text-crash-red border border-crash-red/30';
    } else {
      bar.className = 'mb-4 px-4 py-3 rounded-lg text-sm bg-blue-500/10 text-blue-400 border border-blue-500/30';
    }
    bar.textContent = msg;
  }

  // Load content
  async function loadContent() {
    const lang = (document.getElementById('lang-select') as HTMLSelectElement).value;
    const pageSlug = (document.getElementById('page-select') as HTMLSelectElement).value;

    showStatus('Loading content...', 'info');

    try {
      const res = await fetch(`/api/content/pages?lang=${lang}&page_slug=${pageSlug}`);

      if (res.ok) {
        const data = await res.json();
        const page = data.pageContent || data.page || data;

        if (page && page.id) {
          currentContentId = page.id;
          (document.getElementById('content-editor') as HTMLTextAreaElement).value = page.content || '';
          (document.getElementById('meta-title') as HTMLInputElement).value = page.meta_title || page.metaTitle || '';
          (document.getElementById('meta-description') as HTMLInputElement).value = page.meta_description || page.metaDescription || '';
          faqItems = [];
          try {
            const faqRaw = page.faq_data || page.faqData;
            if (faqRaw) {
              faqItems = typeof faqRaw === 'string' ? JSON.parse(faqRaw) : faqRaw;
            }
          } catch (e) { faqItems = []; }
          renderFaq();
          updatePreview();
          showStatus(`Content loaded for ${lang} / ${pageSlug}`, 'success');
        } else {
          currentContentId = null;
          (document.getElementById('content-editor') as HTMLTextAreaElement).value = '';
          (document.getElementById('meta-title') as HTMLInputElement).value = '';
          (document.getElementById('meta-description') as HTMLInputElement).value = '';
          faqItems = [];
          renderFaq();
          updatePreview();
          showStatus(`No content found for ${lang} / ${pageSlug}. Create new content below.`, 'info');
        }
      } else {
        currentContentId = null;
        showStatus('No existing content found. You can create new content.', 'info');
      }
    } catch (err) {
      showStatus('Failed to load content. Check network connection.', 'error');
    }

    updateCharCount();
  }

  // Save content
  async function saveContent() {
    const lang = (document.getElementById('lang-select') as HTMLSelectElement).value;
    const pageSlug = (document.getElementById('page-select') as HTMLSelectElement).value;
    const content = (document.getElementById('content-editor') as HTMLTextAreaElement).value;
    const metaTitle = (document.getElementById('meta-title') as HTMLInputElement).value;
    const metaDescription = (document.getElementById('meta-description') as HTMLInputElement).value;

    if (!content.trim()) {
      showStatus('Content cannot be empty.', 'error');
      return;
    }

    showStatus('Saving content...', 'info');

    const payload = {
      pageSlug,
      lang,
      title: metaTitle || pageSlug,
      content,
      metaTitle,
      metaDescription,
      faqData: JSON.stringify(faqItems),
    };

    try {
      const url = currentContentId
        ? `/api/content/pages?id=${currentContentId}`
        : '/api/content/pages';
      const method = currentContentId ? 'PUT' : 'POST';

      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        const data = await res.json();
        if (data.pageContent?.id) currentContentId = data.pageContent.id;
        showStatus('Content saved successfully!', 'success');
      } else {
        const data = await res.json();
        showStatus(`Save failed: ${data.error || 'Unknown error'}`, 'error');
      }
    } catch (err) {
      showStatus('Network error while saving.', 'error');
    }
  }

  // Generate with AI
  async function generateContent() {
    const lang = (document.getElementById('lang-select') as HTMLSelectElement).value;
    const pageSlug = (document.getElementById('page-select') as HTMLSelectElement).value;

    const keyword = prompt('Enter the main keyword for content generation:', `Big Bass Crash ${pageSlug}`);
    if (!keyword) return;

    showStatus('Generating content with AI... This may take a moment.', 'info');
    const btn = document.getElementById('btn-generate') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Generating...';

    try {
      const res = await fetch('/api/content/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pageSlug, lang, keyword }),
      });

      if (res.ok) {
        const data = await res.json();
        const generated = data.pageContent;
        if (generated) {
          currentContentId = generated.id;
          (document.getElementById('content-editor') as HTMLTextAreaElement).value = generated.content || '';
          (document.getElementById('meta-title') as HTMLInputElement).value = generated.meta_title || generated.metaTitle || '';
          (document.getElementById('meta-description') as HTMLInputElement).value = generated.meta_description || generated.metaDescription || '';
          updatePreview();
          updateCharCount();
        }
        showStatus('Content generated successfully! Review and save.', 'success');
      } else {
        const data = await res.json();
        showStatus(`Generation failed: ${data.error || 'Unknown error'}`, 'error');
      }
    } catch (err) {
      showStatus('Network error during generation.', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Generate with AI';
    }
  }

  // Simple markdown to HTML preview
  function markdownToHtml(md: string): string {
    let html = md
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/^### (.*$)/gm, '<h3 class="text-lg font-semibold text-white mt-4 mb-2">$1</h3>')
      .replace(/^## (.*$)/gm, '<h2 class="text-xl font-semibold text-white mt-5 mb-2">$1</h2>')
      .replace(/^# (.*$)/gm, '<h1 class="text-2xl font-bold text-white mt-6 mb-3">$1</h1>')
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/^\- (.*$)/gm, '<li class="ml-4">$1</li>')
      .replace(/^\d+\. (.*$)/gm, '<li class="ml-4 list-decimal">$1</li>')
      .replace(/\n\n/g, '</p><p class="mb-3">')
      .replace(/\n/g, '<br>');
    return `<p class="mb-3">${html}</p>`;
  }

  function updatePreview() {
    const content = (document.getElementById('content-editor') as HTMLTextAreaElement).value;
    document.getElementById('content-preview')!.innerHTML = content
      ? markdownToHtml(content)
      : '<p class="text-gray-500 italic">Content preview will appear here...</p>';
  }

  function updateCharCount() {
    const content = (document.getElementById('content-editor') as HTMLTextAreaElement).value;
    document.getElementById('char-count')!.textContent = `${content.length} chars`;
  }

  // FAQ management
  function renderFaq() {
    const container = document.getElementById('faq-container')!;
    if (faqItems.length === 0) {
      container.innerHTML = '<p class="text-gray-500 text-sm italic">No FAQ items. Click "Add FAQ Pair" to create one.</p>';
      return;
    }

    container.innerHTML = faqItems.map((item, i) => `
      <div class="bg-ocean-900/50 border border-ocean-600/10 rounded-lg p-4" data-faq-index="${i}">
        <div class="flex items-start justify-between mb-3">
          <span class="text-xs text-gray-500 uppercase tracking-wide">FAQ #${i + 1}</span>
          <button onclick="removeFaq(${i})" class="text-crash-red hover:text-red-400 text-xs">Remove</button>
        </div>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-gray-400 mb-1">Question</label>
            <input type="text" value="${escapeAttr(item.q)}" onchange="updateFaq(${i}, 'q', this.value)"
              class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm focus:border-accent-500 outline-none" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Answer</label>
            <textarea onchange="updateFaq(${i}, 'a', this.value)" rows="2"
              class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm focus:border-accent-500 outline-none resize-y">${escapeAttr(item.a)}</textarea>
          </div>
        </div>
      </div>
    `).join('');
  }

  function escapeAttr(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  (window as any).updateFaq = function(index: number, field: 'q' | 'a', value: string) {
    if (faqItems[index]) {
      faqItems[index][field] = value;
    }
  };

  (window as any).removeFaq = function(index: number) {
    faqItems.splice(index, 1);
    renderFaq();
  };

  document.getElementById('btn-add-faq')?.addEventListener('click', () => {
    faqItems.push({ q: '', a: '' });
    renderFaq();
  });

  // Event listeners
  document.getElementById('btn-load')?.addEventListener('click', loadContent);
  document.getElementById('btn-generate')?.addEventListener('click', generateContent);
  document.getElementById('btn-save')?.addEventListener('click', saveContent);
  document.getElementById('content-editor')?.addEventListener('input', () => {
    updatePreview();
    updateCharCount();
  });

  // Auto-load on page/lang change
  document.getElementById('lang-select')?.addEventListener('change', loadContent);
  document.getElementById('page-select')?.addEventListener('change', loadContent);

  // Init
  loadContent();
</script>
