---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Manage Casinos" currentPage="casinos">
  <!-- Action Bar -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
    <div class="flex items-center gap-4 flex-wrap">
      <div class="flex items-center gap-2">
        <label for="lang-selector" class="text-gray-400 text-sm whitespace-nowrap">Order for:</label>
        <select id="lang-selector" class="bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm focus:border-accent-500 outline-none min-w-[200px]">
          <option value="">Global (Default)</option>
          <option value="en">&#127468;&#127463; English</option>
          <option value="ru">&#127479;&#127482; Russian</option>
          <option value="de">&#127465;&#127466; German</option>
          <option value="fr">&#127467;&#127479; French</option>
          <option value="es">&#127466;&#127480; Spanish</option>
          <option value="pt">&#127477;&#127481; Portuguese</option>
          <option value="it">&#127470;&#127481; Italian</option>
          <option value="nl">&#127475;&#127473; Dutch</option>
          <option value="pl">&#127477;&#127473; Polish</option>
          <option value="cs">&#127464;&#127487; Czech</option>
          <option value="sk">&#127480;&#127472; Slovak</option>
          <option value="hu">&#127469;&#127482; Hungarian</option>
          <option value="ro">&#127479;&#127476; Romanian</option>
          <option value="bg">&#127463;&#127468; Bulgarian</option>
          <option value="hr">&#127469;&#127479; Croatian</option>
          <option value="sl">&#127480;&#127470; Slovenian</option>
          <option value="sr">&#127479;&#127480; Serbian</option>
          <option value="uk">&#127482;&#127462; Ukrainian</option>
          <option value="tr">&#127481;&#127479; Turkish</option>
          <option value="el">&#127468;&#127479; Greek</option>
          <option value="ar">&#127480;&#127462; Arabic</option>
          <option value="he">&#127470;&#127473; Hebrew</option>
          <option value="hi">&#127470;&#127475; Hindi</option>
          <option value="bn">&#127463;&#127465; Bengali</option>
          <option value="ja">&#127471;&#127477; Japanese</option>
          <option value="ko">&#127472;&#127479; Korean</option>
          <option value="zh">&#127464;&#127475; Chinese</option>
          <option value="th">&#127481;&#127469; Thai</option>
          <option value="vi">&#127483;&#127475; Vietnamese</option>
          <option value="id">&#127470;&#127465; Indonesian</option>
          <option value="ms">&#127474;&#127486; Malay</option>
          <option value="fil">&#127477;&#127469; Filipino</option>
          <option value="sv">&#127480;&#127466; Swedish</option>
          <option value="no">&#127475;&#127476; Norwegian</option>
          <option value="da">&#127465;&#127472; Danish</option>
          <option value="fi">&#127467;&#127470; Finnish</option>
          <option value="et">&#127466;&#127466; Estonian</option>
          <option value="lv">&#127473;&#127483; Latvian</option>
          <option value="lt">&#127473;&#127481; Lithuanian</option>
          <option value="ka">&#127468;&#127466; Georgian</option>
        </select>
      </div>
      <p class="text-gray-400 text-sm">Drag rows to reorder. Changes auto-save.</p>
    </div>
    <button id="btn-add-casino" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
      + Add Casino
    </button>
  </div>

  <!-- Language mode indicator -->
  <div id="lang-mode-banner" class="hidden mb-4 bg-ocean-800/70 border border-accent-500/30 rounded-lg px-4 py-2.5 flex items-center gap-2">
    <svg class="w-4 h-4 text-accent-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
    <span class="text-sm text-gray-300">Viewing <strong id="lang-mode-name" class="text-accent-400"></strong> locale order. Drag to reorder for this language. Use the eye icon to show/hide casinos.</span>
  </div>

  <!-- Casino Table -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-ocean-600/20">
            <th class="text-left text-gray-400 font-medium px-4 py-3 w-10"></th>
            <th class="text-left text-gray-400 font-medium px-4 py-3">Name</th>
            <th class="text-left text-gray-400 font-medium px-4 py-3">Brand ID</th>
            <th class="text-left text-gray-400 font-medium px-4 py-3">Rating</th>
            <th class="text-left text-gray-400 font-medium px-4 py-3">Status</th>
            <th class="text-left text-gray-400 font-medium px-4 py-3">Order</th>
            <th id="th-visibility" class="text-left text-gray-400 font-medium px-4 py-3 hidden">Visible</th>
            <th class="text-right text-gray-400 font-medium px-4 py-3">Actions</th>
          </tr>
        </thead>
        <tbody id="casinos-tbody">
          <tr>
            <td colspan="8" class="px-4 py-8 text-center text-gray-500">Loading casinos...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal Overlay -->
  <div id="modal-overlay" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
    <div class="bg-ocean-800 border border-ocean-600/30 rounded-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between p-5 border-b border-ocean-600/20">
        <h3 id="modal-title" class="text-lg font-semibold text-white">Add Casino</h3>
        <button id="modal-close" class="text-gray-400 hover:text-white text-xl">&times;</button>
      </div>
      <form id="casino-form" class="p-5 space-y-4">
        <input type="hidden" id="form-id" value="" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Name *</label>
            <input type="text" id="form-name" required class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Slug *</label>
            <input type="text" id="form-slug" required class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Brand ID *</label>
            <input type="text" id="form-brandId" required class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Rating</label>
            <input type="number" id="form-rating" value="4.5" step="0.1" min="0" max="5" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
          </div>
        </div>

        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Affiliate URL</label>
          <input type="url" id="form-affiliateUrl" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
        </div>

        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Logo Path</label>
          <input type="text" id="form-logoPath" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="/images/casinos/logo.webp" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Bonus Amount</label>
            <input type="text" id="form-bonusAmount" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="$500" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Free Spins</label>
            <input type="text" id="form-freeSpins" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="200" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Min Deposit</label>
            <input type="text" id="form-minDeposit" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="$10" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">License</label>
            <input type="text" id="form-license" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="Curacao" />
          </div>
        </div>

        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Sort Order</label>
          <input type="number" id="form-sortOrder" value="0" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
        </div>

        <div class="flex items-center gap-2">
          <input type="checkbox" id="form-isActive" checked class="w-4 h-4 rounded bg-ocean-900 border-ocean-600" />
          <label for="form-isActive" class="text-sm text-gray-300">Active</label>
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t border-ocean-600/20">
          <button type="button" id="modal-cancel" class="px-4 py-2.5 rounded-lg text-sm text-gray-400 hover:text-white bg-ocean-700 hover:bg-ocean-600 transition-colors">
            Cancel
          </button>
          <button type="submit" class="px-4 py-2.5 rounded-lg text-sm font-medium text-white bg-accent-500 hover:bg-accent-600 transition-colors">
            Save Casino
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  let casinosData: any[] = [];
  let dragSrcIndex: number | null = null;
  let currentLang: string = '';

  // Language selector
  const langSelector = document.getElementById('lang-selector') as HTMLSelectElement;
  const langBanner = document.getElementById('lang-mode-banner')!;
  const langBannerName = document.getElementById('lang-mode-name')!;
  const thVisibility = document.getElementById('th-visibility')!;

  langSelector.addEventListener('change', () => {
    currentLang = langSelector.value;
    if (currentLang) {
      const selectedOption = langSelector.options[langSelector.selectedIndex];
      langBannerName.textContent = selectedOption.textContent?.trim() || currentLang;
      langBanner.classList.remove('hidden');
      thVisibility.classList.remove('hidden');
    } else {
      langBanner.classList.add('hidden');
      thVisibility.classList.add('hidden');
    }
    loadCasinos();
  });

  // Load casinos
  async function loadCasinos() {
    try {
      let res;
      if (currentLang) {
        res = await fetch(`/api/casinos/public?lang=${encodeURIComponent(currentLang)}`);
      } else {
        res = await fetch('/api/casinos/');
      }
      const data = await res.json();
      casinosData = data.casinos || [];
      renderTable();
    } catch (err) {
      document.getElementById('casinos-tbody')!.innerHTML =
        '<tr><td colspan="8" class="px-4 py-8 text-center text-crash-red">Failed to load casinos</td></tr>';
    }
  }

  function renderTable() {
    const tbody = document.getElementById('casinos-tbody')!;
    if (casinosData.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-8 text-center text-gray-500">No casinos found. Add one to get started.</td></tr>';
      return;
    }

    const isLocaleMode = !!currentLang;

    tbody.innerHTML = casinosData.map((c, i) => {
      // Determine visibility: if locale mode, check locale_visible / localeVisible; default true if not set
      const isVisible = isLocaleMode ? (c.locale_visible ?? c.localeVisible ?? true) : true;
      const rowOpacity = (!isLocaleMode || isVisible) ? '' : 'opacity-50';
      const nameDecoration = (!isLocaleMode || isVisible) ? '' : 'line-through';

      return `
      <tr class="border-b border-ocean-600/10 hover:bg-ocean-800/30 transition-colors casino-row ${rowOpacity}" data-id="${c.id}" data-index="${i}" draggable="true">
        <td class="px-4 py-3 cursor-grab text-gray-500 drag-handle">&#x2630;</td>
        <td class="px-4 py-3">
          <div class="flex items-center gap-2">
            ${(c.logoPath || c.logo_path) ? `<img src="${c.logoPath || c.logo_path}" class="w-6 h-6 rounded" alt="" />` : ''}
            <span class="text-white font-medium ${nameDecoration}">${escapeHtml(c.name)}</span>
          </div>
        </td>
        <td class="px-4 py-3 text-gray-400 ${nameDecoration}">${escapeHtml(c.brand_id || c.brandId || '')}</td>
        <td class="px-4 py-3">
          <span class="text-yellow-400">${c.rating ? Number(c.rating).toFixed(1) : '\u2014'}</span>
        </td>
        <td class="px-4 py-3">
          <span class="px-2 py-1 rounded-full text-xs font-medium ${c.is_active || c.isActive ? 'bg-accent-500/20 text-accent-400' : 'bg-gray-600/20 text-gray-400'}">
            ${c.is_active || c.isActive ? 'Active' : 'Inactive'}
          </span>
        </td>
        <td class="px-4 py-3 text-gray-400">${c.sort_order ?? c.sortOrder ?? 0}</td>
        ${isLocaleMode ? `
        <td class="px-4 py-3">
          <button onclick="toggleLocaleVisibility(${c.id}, ${isVisible ? 'false' : 'true'})"
            class="inline-flex items-center justify-center w-8 h-8 rounded-lg transition-colors ${isVisible ? 'bg-accent-500/20 text-accent-400 hover:bg-accent-500/30' : 'bg-gray-600/20 text-gray-500 hover:bg-gray-600/30'}"
            title="${isVisible ? 'Visible - click to hide' : 'Hidden - click to show'}">
            ${isVisible
              ? '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>'
              : '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L3 3m6.878 6.878L21 21" /></svg>'
            }
          </button>
        </td>` : ''}
        <td class="px-4 py-3 text-right">
          <button onclick="editCasino(${c.id})" class="text-accent-400 hover:text-accent-300 text-sm mr-3">Edit</button>
          <button onclick="deleteCasino(${c.id}, '${escapeHtml(c.name)}')" class="text-crash-red hover:text-red-400 text-sm">Delete</button>
        </td>
      </tr>`;
    }).join('');

    // Attach drag events
    attachDragEvents();
  }

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Toggle locale visibility
  (window as any).toggleLocaleVisibility = async function(casinoId: number, newVisible: boolean) {
    if (!currentLang) return;
    try {
      const res = await fetch('/api/casinos/locale-visibility', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ casinoId, lang: currentLang, isVisible: newVisible }),
      });
      if (res.ok) {
        // Update local data and re-render
        const casino = casinosData.find(c => c.id === casinoId);
        if (casino) {
          casino.locale_visible = newVisible;
          casino.localeVisible = newVisible;
        }
        renderTable();
      } else {
        const data = await res.json().catch(() => ({}));
        alert('Failed to update visibility: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error while updating visibility');
    }
  };

  // Drag and drop
  function attachDragEvents() {
    const rows = document.querySelectorAll('.casino-row');
    rows.forEach(row => {
      row.addEventListener('dragstart', (e: any) => {
        dragSrcIndex = parseInt(e.currentTarget.dataset.index);
        e.currentTarget.classList.add('opacity-50');
        e.dataTransfer.effectAllowed = 'move';
      });
      row.addEventListener('dragend', (e: any) => {
        e.currentTarget.classList.remove('opacity-50');
        dragSrcIndex = null;
      });
      row.addEventListener('dragover', (e: any) => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        e.currentTarget.classList.add('bg-ocean-700/30');
      });
      row.addEventListener('dragleave', (e: any) => {
        e.currentTarget.classList.remove('bg-ocean-700/30');
      });
      row.addEventListener('drop', async (e: any) => {
        e.preventDefault();
        e.currentTarget.classList.remove('bg-ocean-700/30');
        const targetIndex = parseInt(e.currentTarget.dataset.index);

        if (dragSrcIndex !== null && dragSrcIndex !== targetIndex) {
          const moved = casinosData.splice(dragSrcIndex, 1)[0];
          casinosData.splice(targetIndex, 0, moved);
          renderTable();
          await saveOrder();
        }
      });
    });
  }

  async function saveOrder() {
    try {
      const ids = casinosData.map(c => c.id);
      if (currentLang) {
        // Save locale-specific order
        await fetch('/api/casinos/reorder-locale', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lang: currentLang, ids }),
        });
      } else {
        // Save global order
        await fetch('/api/casinos/reorder', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids }),
        });
      }
    } catch (err) {
      console.error('Failed to save order:', err);
    }
  }

  // Modal management
  function openModal(title: string) {
    document.getElementById('modal-title')!.textContent = title;
    document.getElementById('modal-overlay')!.classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('modal-overlay')!.classList.add('hidden');
    (document.getElementById('casino-form') as HTMLFormElement).reset();
    (document.getElementById('form-id') as HTMLInputElement).value = '';
  }

  // Add casino
  document.getElementById('btn-add-casino')?.addEventListener('click', () => {
    (document.getElementById('form-id') as HTMLInputElement).value = '';
    (document.getElementById('casino-form') as HTMLFormElement).reset();
    (document.getElementById('form-rating') as HTMLInputElement).value = '4.5';
    (document.getElementById('form-sortOrder') as HTMLInputElement).value = '0';
    (document.getElementById('form-isActive') as HTMLInputElement).checked = true;
    openModal('Add Casino');
  });

  // Edit casino
  (window as any).editCasino = function(id: number) {
    const casino = casinosData.find(c => c.id === id);
    if (!casino) return;

    (document.getElementById('form-id') as HTMLInputElement).value = String(casino.id);
    (document.getElementById('form-name') as HTMLInputElement).value = casino.name || '';
    (document.getElementById('form-slug') as HTMLInputElement).value = casino.slug || '';
    (document.getElementById('form-brandId') as HTMLInputElement).value = casino.brand_id || casino.brandId || '';
    (document.getElementById('form-rating') as HTMLInputElement).value = String(casino.rating ?? 4.5);
    (document.getElementById('form-affiliateUrl') as HTMLInputElement).value = casino.affiliate_url || casino.affiliateUrl || '';
    (document.getElementById('form-logoPath') as HTMLInputElement).value = casino.logo_path || casino.logoPath || '';
    (document.getElementById('form-bonusAmount') as HTMLInputElement).value = casino.bonus_amount || casino.bonusAmount || '';
    (document.getElementById('form-freeSpins') as HTMLInputElement).value = casino.free_spins || casino.freeSpins || '';
    (document.getElementById('form-minDeposit') as HTMLInputElement).value = casino.min_deposit || casino.minDeposit || '';
    (document.getElementById('form-license') as HTMLInputElement).value = casino.license || '';
    (document.getElementById('form-sortOrder') as HTMLInputElement).value = String(casino.sort_order ?? casino.sortOrder ?? 0);
    (document.getElementById('form-isActive') as HTMLInputElement).checked = !!(casino.is_active ?? casino.isActive);
    openModal('Edit Casino');
  };

  // Delete casino
  (window as any).deleteCasino = async function(id: number, name: string) {
    if (!confirm(`Delete casino "${name}"? This cannot be undone.`)) return;
    try {
      const res = await fetch(`/api/casinos/${id}`, { method: 'DELETE' });
      if (res.ok) {
        await loadCasinos();
      } else {
        const data = await res.json();
        alert('Delete failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error while deleting casino');
    }
  };

  // Form submit
  document.getElementById('casino-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const id = (document.getElementById('form-id') as HTMLInputElement).value;
    const payload = {
      name: (document.getElementById('form-name') as HTMLInputElement).value,
      slug: (document.getElementById('form-slug') as HTMLInputElement).value,
      brandId: (document.getElementById('form-brandId') as HTMLInputElement).value,
      rating: parseFloat((document.getElementById('form-rating') as HTMLInputElement).value) || 4.5,
      affiliateUrl: (document.getElementById('form-affiliateUrl') as HTMLInputElement).value || null,
      logoPath: (document.getElementById('form-logoPath') as HTMLInputElement).value || null,
      bonusAmount: (document.getElementById('form-bonusAmount') as HTMLInputElement).value || null,
      freeSpins: (document.getElementById('form-freeSpins') as HTMLInputElement).value || null,
      minDeposit: (document.getElementById('form-minDeposit') as HTMLInputElement).value || null,
      license: (document.getElementById('form-license') as HTMLInputElement).value || null,
      sortOrder: parseInt((document.getElementById('form-sortOrder') as HTMLInputElement).value) || 0,
      isActive: (document.getElementById('form-isActive') as HTMLInputElement).checked,
    };

    try {
      let res;
      if (id) {
        res = await fetch(`/api/casinos/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
      } else {
        res = await fetch('/api/casinos/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
      }

      if (res.ok) {
        closeModal();
        await loadCasinos();
      } else {
        const data = await res.json();
        alert('Save failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error while saving casino');
    }
  });

  // Auto-generate slug
  document.getElementById('form-name')?.addEventListener('input', (e) => {
    const id = (document.getElementById('form-id') as HTMLInputElement).value;
    if (!id) {
      const name = (e.target as HTMLInputElement).value;
      (document.getElementById('form-slug') as HTMLInputElement).value = name
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '');
    }
  });

  // Close modal
  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
  document.getElementById('modal-overlay')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeModal();
  });

  // Init
  loadCasinos();
</script>
