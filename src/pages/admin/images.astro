---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Image Manager" currentPage="images">
  <!-- Bing Image Fetcher -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6 mb-6">
    <h2 class="text-lg font-semibold text-white mb-4">Fetch Images from Bing</h2>
    <div class="flex gap-3 mb-4">
      <input type="text" id="search-keywords" class="flex-1 bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="Enter tail keywords (e.g. big bass bonanza slot gameplay)" />
      <select id="search-category" class="bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none">
        <option value="game">Game</option>
        <option value="casinos">Casinos</option>
        <option value="experts">Experts</option>
        <option value="og">OG Images</option>
        <option value="icons">Icons</option>
      </select>
      <button id="btn-search-images" class="bg-accent-500 hover:bg-accent-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors whitespace-nowrap">
        Search Images
      </button>
    </div>

    <!-- Search Results Preview -->
    <div id="search-results" class="hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-medium text-gray-300">Search Results (click to select)</h3>
        <button id="btn-download-selected" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded-lg text-xs font-medium transition-colors disabled:opacity-40" disabled>
          Download Selected (0)
        </button>
      </div>
      <div id="search-results-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      </div>
    </div>

    <!-- Search Status -->
    <div id="search-status" class="hidden text-sm text-gray-400 mt-3"></div>
  </div>

  <!-- Upload Custom Image -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6 mb-6">
    <h2 class="text-lg font-semibold text-white mb-4">Upload Custom Image</h2>
    <form id="upload-form" class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Image File</label>
          <input type="file" id="upload-file" accept="image/*" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2 text-white text-sm file:mr-3 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-accent-500 file:text-white hover:file:bg-accent-600" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Category</label>
          <select id="upload-category" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none">
            <option value="game">Game</option>
            <option value="casinos">Casinos</option>
            <option value="experts">Experts</option>
            <option value="og">OG Images</option>
            <option value="icons">Icons</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Alt Text (English)</label>
          <input type="text" id="upload-alt" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="Image description" />
        </div>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
          Upload Image
        </button>
        <span id="upload-status" class="hidden text-sm text-gray-400 self-center"></span>
      </div>
    </form>
  </div>

  <!-- Existing Images Grid -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Image Library</h2>
      <div class="flex gap-2">
        <select id="filter-category" class="bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm focus:border-accent-500 outline-none">
          <option value="">All Categories</option>
          <option value="game">Game</option>
          <option value="casinos">Casinos</option>
          <option value="experts">Experts</option>
          <option value="og">OG Images</option>
          <option value="icons">Icons</option>
        </select>
        <button id="btn-refresh-images" class="bg-ocean-700 hover:bg-ocean-600 border border-ocean-600/30 text-white px-3 py-2 rounded-lg text-sm transition-colors">
          Refresh
        </button>
      </div>
    </div>

    <div id="images-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      <div class="col-span-full text-center py-8 text-gray-500 text-sm">Loading images...</div>
    </div>
  </div>

  <!-- Image Detail Modal -->
  <div id="image-modal" class="hidden fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-4">
    <div class="bg-ocean-800 border border-ocean-600/30 rounded-xl w-full max-w-lg">
      <div class="flex items-center justify-between p-5 border-b border-ocean-600/20">
        <h3 class="text-lg font-semibold text-white">Image Details</h3>
        <button id="image-modal-close" class="text-gray-400 hover:text-white text-xl">&times;</button>
      </div>
      <div class="p-5 space-y-4">
        <div class="flex justify-center">
          <img id="modal-image-preview" class="max-h-48 rounded-lg border border-ocean-600/20" src="" alt="" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Path</label>
          <p id="modal-image-path" class="text-sm text-white bg-ocean-900 px-3 py-2 rounded-lg break-all"></p>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Category</label>
          <p id="modal-image-category" class="text-sm text-gray-300"></p>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Dimensions</label>
          <p id="modal-image-dims" class="text-sm text-gray-300"></p>
        </div>
        <div class="flex justify-between pt-4 border-t border-ocean-600/20">
          <button id="btn-copy-path" class="text-accent-400 hover:text-accent-300 text-sm font-medium transition-colors">
            Copy Path
          </button>
          <button id="btn-delete-image" class="text-crash-red hover:text-red-400 text-sm font-medium transition-colors">
            Delete Image
          </button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  let imagesData: any[] = [];
  let selectedSearchImages: Set<string> = new Set();
  let currentModalImageId: number | null = null;

  // ============ SEARCH IMAGES ============
  document.getElementById('btn-search-images')?.addEventListener('click', async () => {
    const keywords = (document.getElementById('search-keywords') as HTMLInputElement).value.trim();
    if (!keywords) {
      alert('Please enter search keywords.');
      return;
    }

    const btn = document.getElementById('btn-search-images') as HTMLButtonElement;
    const statusEl = document.getElementById('search-status')!;
    const resultsContainer = document.getElementById('search-results')!;

    btn.disabled = true;
    btn.textContent = 'Searching...';
    statusEl.classList.remove('hidden');
    statusEl.textContent = 'Searching Bing for images...';
    selectedSearchImages.clear();
    updateDownloadCount();

    try {
      const res = await fetch('/api/images/search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ keywords }),
      });

      if (res.ok) {
        const data = await res.json();
        const images = data.images || [];

        if (images.length === 0) {
          statusEl.textContent = 'No images found. Try different keywords.';
          resultsContainer.classList.add('hidden');
          return;
        }

        statusEl.textContent = `Found ${images.length} images. Click to select, then download.`;
        resultsContainer.classList.remove('hidden');
        renderSearchResults(images);
      } else {
        const data = await res.json();
        statusEl.textContent = `Search failed: ${data.error || 'Unknown error'}`;
      }
    } catch (err) {
      statusEl.textContent = 'Network error during search.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Search Images';
    }
  });

  function renderSearchResults(images: any[]) {
    const grid = document.getElementById('search-results-grid')!;
    grid.innerHTML = images.map((img, i) => `
      <div class="search-result-item relative rounded-lg overflow-hidden border-2 cursor-pointer transition-all
        ${selectedSearchImages.has(img.url) ? 'border-accent-500' : 'border-ocean-600/20 hover:border-ocean-600/50'}"
        data-url="${escapeAttr(img.url)}" onclick="toggleSearchImage(this, '${escapeAttr(img.url)}')">
        <img src="${img.thumbnail || img.url}" alt="" class="w-full aspect-square object-cover" loading="lazy"
          onerror="this.parentElement.style.display='none'" />
        <div class="absolute inset-0 bg-black/0 hover:bg-black/20 transition-colors flex items-center justify-center">
          <div class="check-icon hidden w-8 h-8 bg-accent-500 rounded-full flex items-center justify-center text-white text-lg">
            &#10003;
          </div>
        </div>
        ${img.width && img.height ? `<span class="absolute bottom-1 right-1 text-xs bg-black/60 text-gray-300 px-1.5 py-0.5 rounded">${img.width}x${img.height}</span>` : ''}
      </div>
    `).join('');
  }

  function escapeAttr(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  (window as any).toggleSearchImage = function(el: HTMLElement, url: string) {
    if (selectedSearchImages.has(url)) {
      selectedSearchImages.delete(url);
      el.classList.remove('border-accent-500');
      el.classList.add('border-ocean-600/20');
      el.querySelector('.check-icon')?.classList.add('hidden');
    } else {
      selectedSearchImages.add(url);
      el.classList.add('border-accent-500');
      el.classList.remove('border-ocean-600/20');
      el.querySelector('.check-icon')?.classList.remove('hidden');
    }
    updateDownloadCount();
  };

  function updateDownloadCount() {
    const btn = document.getElementById('btn-download-selected') as HTMLButtonElement;
    const count = selectedSearchImages.size;
    btn.textContent = `Download Selected (${count})`;
    btn.disabled = count === 0;
  }

  // Download selected
  document.getElementById('btn-download-selected')?.addEventListener('click', async () => {
    if (selectedSearchImages.size === 0) return;

    const category = (document.getElementById('search-category') as HTMLSelectElement).value;
    const btn = document.getElementById('btn-download-selected') as HTMLButtonElement;
    const statusEl = document.getElementById('search-status')!;

    btn.disabled = true;
    btn.textContent = 'Downloading...';
    statusEl.textContent = `Downloading ${selectedSearchImages.size} images...`;

    const urls = Array.from(selectedSearchImages);
    let successCount = 0;
    let failCount = 0;

    for (const url of urls) {
      try {
        const res = await fetch('/api/images/download', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url, category }),
        });

        if (res.ok) {
          successCount++;
        } else {
          failCount++;
        }
      } catch {
        failCount++;
      }
    }

    statusEl.textContent = `Downloaded: ${successCount} success, ${failCount} failed.`;
    selectedSearchImages.clear();
    updateDownloadCount();
    btn.disabled = false;
    await loadImages();
  });

  // ============ UPLOAD IMAGE ============
  document.getElementById('upload-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const fileInput = document.getElementById('upload-file') as HTMLInputElement;
    const category = (document.getElementById('upload-category') as HTMLSelectElement).value;
    const altText = (document.getElementById('upload-alt') as HTMLInputElement).value;
    const statusEl = document.getElementById('upload-status')!;

    if (!fileInput.files || fileInput.files.length === 0) {
      alert('Please select a file.');
      return;
    }

    statusEl.classList.remove('hidden');
    statusEl.textContent = 'Uploading...';

    const formData = new FormData();
    formData.append('file', fileInput.files[0]);
    formData.append('category', category);
    formData.append('altText', altText);

    try {
      const res = await fetch('/api/images/upload', {
        method: 'POST',
        body: formData,
      });

      if (res.ok) {
        statusEl.textContent = 'Upload successful!';
        statusEl.className = 'text-sm text-accent-400 self-center';
        (document.getElementById('upload-form') as HTMLFormElement).reset();
        await loadImages();
      } else {
        const data = await res.json();
        statusEl.textContent = `Upload failed: ${data.error || 'Unknown error'}`;
        statusEl.className = 'text-sm text-crash-red self-center';
      }
    } catch (err) {
      statusEl.textContent = 'Network error during upload.';
      statusEl.className = 'text-sm text-crash-red self-center';
    }
  });

  // ============ IMAGE LIBRARY ============
  async function loadImages() {
    const category = (document.getElementById('filter-category') as HTMLSelectElement).value;

    try {
      let url = '/api/images/';
      if (category) url += `?category=${category}`;

      const res = await fetch(url);
      if (res.ok) {
        const data = await res.json();
        imagesData = data.images || [];
        renderImages();
      } else {
        document.getElementById('images-grid')!.innerHTML =
          '<div class="col-span-full text-center py-8 text-crash-red text-sm">Failed to load images</div>';
      }
    } catch (err) {
      document.getElementById('images-grid')!.innerHTML =
        '<div class="col-span-full text-center py-8 text-crash-red text-sm">Network error</div>';
    }
  }

  function renderImages() {
    const grid = document.getElementById('images-grid')!;

    if (imagesData.length === 0) {
      grid.innerHTML = '<div class="col-span-full text-center py-8 text-gray-500 text-sm">No images found. Upload or fetch images to get started.</div>';
      return;
    }

    grid.innerHTML = imagesData.map(img => `
      <div class="group relative rounded-lg overflow-hidden border border-ocean-600/20 hover:border-ocean-600/50 cursor-pointer transition-all bg-ocean-900/50"
        onclick="openImageModal(${img.id})">
        <img src="${img.local_path || img.localPath}" alt="${escapeAttr(img.alt_text || img.altText || '')}" class="w-full aspect-square object-cover" loading="lazy"
          onerror="this.src='/images/placeholder.webp'" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-2">
          <span class="text-xs text-white truncate w-full">${escapeAttr(img.category || 'unknown')}</span>
        </div>
      </div>
    `).join('');
  }

  // ============ IMAGE MODAL ============
  (window as any).openImageModal = function(id: number) {
    const img = imagesData.find(i => i.id === id);
    if (!img) return;

    currentModalImageId = id;
    const path = img.local_path || img.localPath;
    (document.getElementById('modal-image-preview') as HTMLImageElement).src = path;
    document.getElementById('modal-image-path')!.textContent = path;
    document.getElementById('modal-image-category')!.textContent = img.category || 'Unknown';
    document.getElementById('modal-image-dims')!.textContent =
      img.width && img.height ? `${img.width} x ${img.height}` : 'Unknown';
    document.getElementById('image-modal')!.classList.remove('hidden');
  };

  function closeImageModal() {
    document.getElementById('image-modal')!.classList.add('hidden');
    currentModalImageId = null;
  }

  document.getElementById('image-modal-close')?.addEventListener('click', closeImageModal);
  document.getElementById('image-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeImageModal();
  });

  // Copy path
  document.getElementById('btn-copy-path')?.addEventListener('click', () => {
    const path = document.getElementById('modal-image-path')!.textContent || '';
    navigator.clipboard.writeText(path).then(() => {
      const btn = document.getElementById('btn-copy-path')!;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy Path'; }, 2000);
    });
  });

  // Delete image
  document.getElementById('btn-delete-image')?.addEventListener('click', async () => {
    if (!currentModalImageId) return;
    if (!confirm('Delete this image? This cannot be undone.')) return;

    try {
      const res = await fetch(`/api/images/${currentModalImageId}`, { method: 'DELETE' });
      if (res.ok) {
        closeImageModal();
        await loadImages();
      } else {
        const data = await res.json();
        alert('Delete failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error');
    }
  });

  // ============ EVENTS ============
  document.getElementById('filter-category')?.addEventListener('change', loadImages);
  document.getElementById('btn-refresh-images')?.addEventListener('click', loadImages);

  // Init
  loadImages();
</script>
