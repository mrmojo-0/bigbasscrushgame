---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../lib/db/index';
import { casinos, comments, pageContent, agents } from '../../lib/db/schema';
import { sql, eq } from 'drizzle-orm';

// Fetch stats
const totalCasinos = db.select({ count: sql<number>`count(*)` }).from(casinos).get()?.count ?? 0;
const totalComments = db.select({ count: sql<number>`count(*)` }).from(comments).get()?.count ?? 0;
const totalContent = db.select({ count: sql<number>`count(*)` }).from(pageContent).get()?.count ?? 0;
const activeAgents = db.select({ count: sql<number>`count(*)` }).from(agents).where(eq(agents.isActive, true)).get()?.count ?? 0;

// Recent comments
const recentComments = db
  .select()
  .from(comments)
  .orderBy(sql`${comments.createdAt} DESC`)
  .limit(5)
  .all();
---

<AdminLayout title="Dashboard" currentPage="dashboard">
  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-gray-400 text-sm">Total Casinos</span>
        <span class="text-2xl">🎰</span>
      </div>
      <p class="text-3xl font-bold text-white">{totalCasinos}</p>
      <p class="text-xs text-gray-500 mt-1">Active listings</p>
    </div>

    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-gray-400 text-sm">Total Comments</span>
        <span class="text-2xl">💬</span>
      </div>
      <p class="text-3xl font-bold text-white">{totalComments}</p>
      <p class="text-xs text-gray-500 mt-1">Across all pages</p>
    </div>

    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-gray-400 text-sm">Content Pages</span>
        <span class="text-2xl">📝</span>
      </div>
      <p class="text-3xl font-bold text-white">{totalContent}</p>
      <p class="text-xs text-gray-500 mt-1">Language variants</p>
    </div>

    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-gray-400 text-sm">Active Agents</span>
        <span class="text-2xl">🤖</span>
      </div>
      <p class="text-3xl font-bold text-white">{activeAgents}</p>
      <p class="text-xs text-gray-500 mt-1">AI comment generators</p>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6 mb-8">
    <h2 class="text-lg font-semibold text-white mb-4">Quick Actions</h2>
    <div class="flex flex-wrap gap-3">
      <button id="btn-generate-content" class="bg-accent-500 hover:bg-accent-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
        Generate Content
      </button>
      <button id="btn-rebuild-site" class="bg-ocean-700 hover:bg-ocean-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors border border-ocean-600/30">
        Rebuild Site
      </button>
      <a href="/admin/casinos" class="bg-ocean-700 hover:bg-ocean-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors border border-ocean-600/30 inline-block">
        Manage Casinos
      </a>
      <a href="/admin/comments" class="bg-ocean-700 hover:bg-ocean-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors border border-ocean-600/30 inline-block">
        Manage Comments
      </a>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6">
    <h2 class="text-lg font-semibold text-white mb-4">Recent Activity</h2>
    {recentComments.length > 0 ? (
      <div class="space-y-3">
        {recentComments.map((comment) => (
          <div class="flex items-start gap-3 p-3 bg-ocean-900/50 rounded-lg border border-ocean-600/10">
            <div class="w-8 h-8 bg-ocean-700 rounded-full flex items-center justify-center text-xs text-gray-300 flex-shrink-0">
              {comment.authorName?.charAt(0)?.toUpperCase() || '?'}
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-medium text-white">{comment.authorName}</span>
                <span class="text-xs text-gray-500">on {comment.pageSlug} ({comment.lang})</span>
              </div>
              <p class="text-sm text-gray-400 truncate">{comment.content}</p>
            </div>
            <span class="text-xs text-gray-600 flex-shrink-0">
              {comment.createdAt ? new Date(comment.createdAt).toLocaleDateString() : 'N/A'}
            </span>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-8">
        <p class="text-gray-500 text-sm">No recent activity yet.</p>
        <p class="text-gray-600 text-xs mt-1">Comments and content generation events will appear here.</p>
      </div>
    )}
  </div>

  <!-- Build Status -->
  <div id="build-status" class="hidden mt-4 bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-4">
    <div class="flex items-center gap-3">
      <div id="build-spinner" class="w-5 h-5 border-2 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
      <span id="build-status-text" class="text-sm text-gray-300">Building site...</span>
    </div>
  </div>
</AdminLayout>

<script>
  // Generate Content
  document.getElementById('btn-generate-content')?.addEventListener('click', () => {
    window.location.href = '/admin/content';
  });

  // Rebuild Site
  document.getElementById('btn-rebuild-site')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-rebuild-site') as HTMLButtonElement;
    const statusEl = document.getElementById('build-status')!;
    const statusText = document.getElementById('build-status-text')!;

    btn.disabled = true;
    btn.textContent = 'Building...';
    statusEl.classList.remove('hidden');
    statusText.textContent = 'Triggering site rebuild...';

    try {
      const res = await fetch('/api/build/trigger', { method: 'POST' });
      const data = await res.json();

      if (res.ok) {
        statusText.textContent = 'Build triggered successfully!';
        statusEl.classList.remove('border-ocean-600/20');
        statusEl.classList.add('border-accent-500/30');
        document.getElementById('build-spinner')?.classList.add('hidden');
      } else {
        statusText.textContent = `Build failed: ${data.error || 'Unknown error'}`;
        statusEl.classList.add('border-crash-red/30');
        document.getElementById('build-spinner')?.classList.add('hidden');
      }
    } catch (err) {
      statusText.textContent = 'Error triggering build. Check API endpoint.';
      statusEl.classList.add('border-crash-red/30');
      document.getElementById('build-spinner')?.classList.add('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Rebuild Site';
    }
  });
</script>
