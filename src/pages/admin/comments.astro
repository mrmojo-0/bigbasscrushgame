---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Comments & Agents" currentPage="comments">
  <!-- Tabs -->
  <div class="flex gap-1 mb-6 bg-ocean-800/50 border border-ocean-600/20 rounded-lg p-1 w-fit">
    <button id="tab-comments" class="px-4 py-2 rounded-md text-sm font-medium transition-colors bg-accent-500/20 text-accent-400">
      Comments
    </button>
    <button id="tab-agents" class="px-4 py-2 rounded-md text-sm font-medium transition-colors text-gray-400 hover:text-white">
      AI Agents
    </button>
  </div>

  <!-- Comments Tab -->
  <div id="panel-comments">
    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-4">
      <select id="comment-filter-page" class="bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm focus:border-accent-500 outline-none">
        <option value="">All Pages</option>
        <option value="home">Home</option>
        <option value="play-free">Play Free</option>
        <option value="where-to-play">Where to Play</option>
        <option value="review">Review</option>
      </select>
      <select id="comment-filter-lang" class="bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm focus:border-accent-500 outline-none">
        <option value="">All Languages</option>
        <option value="en">English</option>
        <option value="ru">Russian</option>
        <option value="de">German</option>
        <option value="fr">French</option>
        <option value="es">Spanish</option>
        <option value="pt">Portuguese</option>
        <option value="it">Italian</option>
        <option value="ja">Japanese</option>
        <option value="ko">Korean</option>
        <option value="zh">Chinese</option>
        <option value="tr">Turkish</option>
        <option value="pl">Polish</option>
        <option value="nl">Dutch</option>
        <option value="sv">Swedish</option>
        <option value="no">Norwegian</option>
        <option value="da">Danish</option>
        <option value="fi">Finnish</option>
        <option value="ar">Arabic</option>
        <option value="hi">Hindi</option>
        <option value="th">Thai</option>
        <option value="vi">Vietnamese</option>
        <option value="id">Indonesian</option>
      </select>
      <button id="btn-filter-comments" class="bg-ocean-700 hover:bg-ocean-600 border border-ocean-600/30 text-white px-4 py-2 rounded-lg text-sm transition-colors">
        Filter
      </button>
      <button id="btn-generate-comment" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors ml-auto">
        Generate Comment
      </button>
    </div>

    <!-- Comments List -->
    <div id="comments-list" class="space-y-3">
      <div class="text-center py-8 text-gray-500 text-sm">Loading comments...</div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-4" id="comments-pagination">
      <span class="text-sm text-gray-500" id="comments-page-info"></span>
      <div class="flex gap-2">
        <button id="btn-prev-page" class="bg-ocean-700 hover:bg-ocean-600 border border-ocean-600/30 text-white px-3 py-1.5 rounded text-sm transition-colors disabled:opacity-40" disabled>
          Previous
        </button>
        <button id="btn-next-page" class="bg-ocean-700 hover:bg-ocean-600 border border-ocean-600/30 text-white px-3 py-1.5 rounded text-sm transition-colors disabled:opacity-40" disabled>
          Next
        </button>
      </div>
    </div>
  </div>

  <!-- Agents Tab -->
  <div id="panel-agents" class="hidden">
    <!-- Agent Controls -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex gap-3">
        <button id="btn-add-agent" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
          + Add Agent
        </button>
      </div>
      <div class="flex items-center gap-3">
        <label class="text-sm text-gray-400">Frequency (hours):</label>
        <input type="number" id="agent-frequency" value="4" min="1" max="168" class="w-20 bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm focus:border-accent-500 outline-none" />
        <button id="btn-start-scheduler" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
          Start Scheduler
        </button>
        <button id="btn-stop-scheduler" class="bg-crash-red hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
          Stop Scheduler
        </button>
      </div>
    </div>

    <!-- Agents List -->
    <div id="agents-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="text-center py-8 text-gray-500 text-sm col-span-2">Loading agents...</div>
    </div>
  </div>

  <!-- Agent Modal -->
  <div id="agent-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
    <div class="bg-ocean-800 border border-ocean-600/30 rounded-xl w-full max-w-lg">
      <div class="flex items-center justify-between p-5 border-b border-ocean-600/20">
        <h3 id="agent-modal-title" class="text-lg font-semibold text-white">Add Agent</h3>
        <button id="agent-modal-close" class="text-gray-400 hover:text-white text-xl">&times;</button>
      </div>
      <form id="agent-form" class="p-5 space-y-4">
        <input type="hidden" id="agent-form-id" value="" />
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Name *</label>
          <input type="text" id="agent-form-name" required class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="e.g. Lucky Mike" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Avatar URL</label>
          <input type="text" id="agent-form-avatar" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="/images/avatars/mike.webp" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Personality *</label>
          <textarea id="agent-form-personality" required rows="3" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none resize-y" placeholder="Enthusiastic slot player who loves big wins..."></textarea>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Writing Style</label>
          <input type="text" id="agent-form-style" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="casual, uses emojis, short sentences" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Languages (comma-separated)</label>
          <input type="text" id="agent-form-languages" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="en, de, fr" />
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="agent-form-active" checked class="w-4 h-4 rounded bg-ocean-900 border-ocean-600" />
          <label for="agent-form-active" class="text-sm text-gray-300">Active</label>
        </div>
        <div class="flex justify-end gap-3 pt-4 border-t border-ocean-600/20">
          <button type="button" id="agent-modal-cancel" class="px-4 py-2.5 rounded-lg text-sm text-gray-400 hover:text-white bg-ocean-700 hover:bg-ocean-600 transition-colors">Cancel</button>
          <button type="submit" class="px-4 py-2.5 rounded-lg text-sm font-medium text-white bg-accent-500 hover:bg-accent-600 transition-colors">Save Agent</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  // Tab switching
  let activeTab = 'comments';

  function switchTab(tab: string) {
    activeTab = tab;
    const tabComments = document.getElementById('tab-comments')!;
    const tabAgents = document.getElementById('tab-agents')!;
    const panelComments = document.getElementById('panel-comments')!;
    const panelAgents = document.getElementById('panel-agents')!;

    if (tab === 'comments') {
      tabComments.className = 'px-4 py-2 rounded-md text-sm font-medium transition-colors bg-accent-500/20 text-accent-400';
      tabAgents.className = 'px-4 py-2 rounded-md text-sm font-medium transition-colors text-gray-400 hover:text-white';
      panelComments.classList.remove('hidden');
      panelAgents.classList.add('hidden');
    } else {
      tabAgents.className = 'px-4 py-2 rounded-md text-sm font-medium transition-colors bg-accent-500/20 text-accent-400';
      tabComments.className = 'px-4 py-2 rounded-md text-sm font-medium transition-colors text-gray-400 hover:text-white';
      panelAgents.classList.remove('hidden');
      panelComments.classList.add('hidden');
      loadAgents();
    }
  }

  document.getElementById('tab-comments')?.addEventListener('click', () => switchTab('comments'));
  document.getElementById('tab-agents')?.addEventListener('click', () => switchTab('agents'));

  // ============ COMMENTS ============
  let commentsPage = 1;
  let commentsHasMore = false;

  async function loadComments() {
    const pageSlug = (document.getElementById('comment-filter-page') as HTMLSelectElement).value;
    const lang = (document.getElementById('comment-filter-lang') as HTMLSelectElement).value;

    let url = `/api/comments/?page=${commentsPage}&limit=15`;
    if (pageSlug) url += `&page_slug=${pageSlug}`;
    if (lang) url += `&lang=${lang}`;

    try {
      const res = await fetch(url);
      const data = await res.json();
      const commentsList = data.comments || [];
      commentsHasMore = data.hasMore || false;

      renderComments(commentsList);
      updatePagination();
    } catch (err) {
      document.getElementById('comments-list')!.innerHTML =
        '<div class="text-center py-8 text-crash-red text-sm">Failed to load comments</div>';
    }
  }

  function renderComments(commentsList: any[]) {
    const container = document.getElementById('comments-list')!;

    if (commentsList.length === 0) {
      container.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm">No comments found.</div>';
      return;
    }

    container.innerHTML = commentsList.map(c => `
      <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-lg p-4" data-comment-id="${c.id}">
        <div class="flex items-start justify-between mb-2">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-ocean-700 rounded-full flex items-center justify-center text-xs text-gray-300 flex-shrink-0">
              ${(c.author_name || c.authorName || '?').charAt(0).toUpperCase()}
            </div>
            <div>
              <span class="text-sm font-medium text-white">${escapeHtml(c.author_name || c.authorName || 'Anonymous')}</span>
              <span class="text-xs text-gray-500 ml-2">${c.page_slug || c.pageSlug || ''} / ${c.lang || ''}</span>
              ${c.rating ? `<span class="text-xs text-yellow-400 ml-2">${'&#9733;'.repeat(c.rating)}</span>` : ''}
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-600">${c.created_at || c.createdAt ? new Date(c.created_at || c.createdAt).toLocaleDateString() : ''}</span>
            <button onclick="deleteComment(${c.id})" class="text-crash-red hover:text-red-400 text-xs ml-2">Delete</button>
          </div>
        </div>
        <div class="comment-content" data-cid="${c.id}">
          <p class="text-sm text-gray-300 comment-text">${escapeHtml(c.content || '')}</p>
          <button onclick="startEditComment(${c.id})" class="text-accent-400 hover:text-accent-300 text-xs mt-2">Edit</button>
        </div>
        <div class="comment-edit hidden" data-cid="${c.id}">
          <textarea class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-3 py-2 text-white text-sm mt-2 resize-y outline-none" rows="3">${escapeHtml(c.content || '')}</textarea>
          <div class="flex gap-2 mt-2">
            <button onclick="saveEditComment(${c.id})" class="text-accent-400 hover:text-accent-300 text-xs">Save</button>
            <button onclick="cancelEditComment(${c.id})" class="text-gray-400 hover:text-white text-xs">Cancel</button>
          </div>
        </div>
      </div>
    `).join('');
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function updatePagination() {
    document.getElementById('comments-page-info')!.textContent = `Page ${commentsPage}`;
    (document.getElementById('btn-prev-page') as HTMLButtonElement).disabled = commentsPage <= 1;
    (document.getElementById('btn-next-page') as HTMLButtonElement).disabled = !commentsHasMore;
  }

  // Inline editing
  (window as any).startEditComment = function(id: number) {
    document.querySelector(`.comment-content[data-cid="${id}"]`)?.classList.add('hidden');
    document.querySelector(`.comment-edit[data-cid="${id}"]`)?.classList.remove('hidden');
  };

  (window as any).cancelEditComment = function(id: number) {
    document.querySelector(`.comment-content[data-cid="${id}"]`)?.classList.remove('hidden');
    document.querySelector(`.comment-edit[data-cid="${id}"]`)?.classList.add('hidden');
  };

  (window as any).saveEditComment = async function(id: number) {
    const editDiv = document.querySelector(`.comment-edit[data-cid="${id}"]`);
    const textarea = editDiv?.querySelector('textarea') as HTMLTextAreaElement;
    if (!textarea) return;

    try {
      const res = await fetch(`/api/comments/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: textarea.value }),
      });

      if (res.ok) {
        await loadComments();
      } else {
        const data = await res.json();
        alert('Save failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error');
    }
  };

  (window as any).deleteComment = async function(id: number) {
    if (!confirm('Delete this comment? This cannot be undone.')) return;
    try {
      const res = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
      if (res.ok) {
        await loadComments();
      } else {
        const data = await res.json();
        alert('Delete failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error');
    }
  };

  // Generate comment
  document.getElementById('btn-generate-comment')?.addEventListener('click', async () => {
    const lang = (document.getElementById('comment-filter-lang') as HTMLSelectElement).value || 'en';
    const pageSlug = (document.getElementById('comment-filter-page') as HTMLSelectElement).value || 'home';
    const btn = document.getElementById('btn-generate-comment') as HTMLButtonElement;

    btn.disabled = true;
    btn.textContent = 'Generating...';

    try {
      const res = await fetch('/api/comments/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pageSlug, lang }),
      });

      if (res.ok) {
        await loadComments();
      } else {
        const data = await res.json();
        alert('Generation failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error during comment generation');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Generate Comment';
    }
  });

  // Pagination
  document.getElementById('btn-filter-comments')?.addEventListener('click', () => {
    commentsPage = 1;
    loadComments();
  });
  document.getElementById('btn-prev-page')?.addEventListener('click', () => {
    if (commentsPage > 1) { commentsPage--; loadComments(); }
  });
  document.getElementById('btn-next-page')?.addEventListener('click', () => {
    if (commentsHasMore) { commentsPage++; loadComments(); }
  });

  // ============ AGENTS ============
  let agentsData: any[] = [];

  async function loadAgents() {
    try {
      const res = await fetch('/api/agents/');
      const data = await res.json();
      agentsData = data.agents || [];
      renderAgents();
    } catch (err) {
      document.getElementById('agents-list')!.innerHTML =
        '<div class="text-center py-8 text-crash-red text-sm col-span-2">Failed to load agents</div>';
    }
  }

  function renderAgents() {
    const container = document.getElementById('agents-list')!;

    if (agentsData.length === 0) {
      container.innerHTML = '<div class="text-center py-8 text-gray-500 text-sm col-span-2">No agents found. Add one to get started.</div>';
      return;
    }

    container.innerHTML = agentsData.map(a => `
      <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-5">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-ocean-700 rounded-full flex items-center justify-center text-sm text-gray-300">
              ${a.avatar ? `<img src="${a.avatar}" class="w-10 h-10 rounded-full object-cover" alt="" />` : (a.name || '?').charAt(0).toUpperCase()}
            </div>
            <div>
              <h3 class="text-white font-medium">${escapeHtml(a.name || '')}</h3>
              <span class="text-xs ${a.is_active || a.isActive ? 'text-accent-400' : 'text-gray-500'}">
                ${a.is_active || a.isActive ? 'Active' : 'Inactive'}
              </span>
            </div>
          </div>
          <div class="flex gap-2">
            <button onclick="editAgent(${a.id})" class="text-accent-400 hover:text-accent-300 text-xs">Edit</button>
            <button onclick="deleteAgent(${a.id})" class="text-crash-red hover:text-red-400 text-xs">Delete</button>
          </div>
        </div>
        <p class="text-sm text-gray-400 mb-2 line-clamp-2">${escapeHtml(a.personality || '')}</p>
        ${a.style ? `<p class="text-xs text-gray-500">Style: ${escapeHtml(a.style)}</p>` : ''}
        ${a.languages ? `<p class="text-xs text-gray-500 mt-1">Languages: ${escapeHtml(typeof a.languages === 'string' ? a.languages : JSON.stringify(a.languages))}</p>` : ''}
        ${a.last_generated_at || a.lastGeneratedAt ? `<p class="text-xs text-gray-600 mt-2">Last generated: ${new Date(a.last_generated_at || a.lastGeneratedAt).toLocaleString()}</p>` : ''}
      </div>
    `).join('');
  }

  // Agent modal
  function openAgentModal(title: string) {
    document.getElementById('agent-modal-title')!.textContent = title;
    document.getElementById('agent-modal')!.classList.remove('hidden');
  }

  function closeAgentModal() {
    document.getElementById('agent-modal')!.classList.add('hidden');
    (document.getElementById('agent-form') as HTMLFormElement).reset();
    (document.getElementById('agent-form-id') as HTMLInputElement).value = '';
  }

  document.getElementById('btn-add-agent')?.addEventListener('click', () => {
    (document.getElementById('agent-form') as HTMLFormElement).reset();
    (document.getElementById('agent-form-id') as HTMLInputElement).value = '';
    (document.getElementById('agent-form-active') as HTMLInputElement).checked = true;
    openAgentModal('Add Agent');
  });

  (window as any).editAgent = function(id: number) {
    const agent = agentsData.find(a => a.id === id);
    if (!agent) return;

    (document.getElementById('agent-form-id') as HTMLInputElement).value = String(agent.id);
    (document.getElementById('agent-form-name') as HTMLInputElement).value = agent.name || '';
    (document.getElementById('agent-form-avatar') as HTMLInputElement).value = agent.avatar || '';
    (document.getElementById('agent-form-personality') as HTMLTextAreaElement).value = agent.personality || '';
    (document.getElementById('agent-form-style') as HTMLInputElement).value = agent.style || '';

    let langs = agent.languages || '';
    if (typeof langs !== 'string') {
      try { langs = JSON.parse(langs).join(', '); } catch { langs = String(langs); }
    }
    (document.getElementById('agent-form-languages') as HTMLInputElement).value = langs;
    (document.getElementById('agent-form-active') as HTMLInputElement).checked = !!(agent.is_active ?? agent.isActive);
    openAgentModal('Edit Agent');
  };

  (window as any).deleteAgent = async function(id: number) {
    if (!confirm('Delete this agent?')) return;
    try {
      const res = await fetch(`/api/agents/${id}`, { method: 'DELETE' });
      if (res.ok) {
        await loadAgents();
      } else {
        const data = await res.json();
        alert('Delete failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error');
    }
  };

  document.getElementById('agent-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('agent-form-id') as HTMLInputElement).value;
    const languagesRaw = (document.getElementById('agent-form-languages') as HTMLInputElement).value;
    const languages = languagesRaw.split(',').map(s => s.trim()).filter(Boolean);

    const payload = {
      name: (document.getElementById('agent-form-name') as HTMLInputElement).value,
      avatar: (document.getElementById('agent-form-avatar') as HTMLInputElement).value || null,
      personality: (document.getElementById('agent-form-personality') as HTMLTextAreaElement).value,
      style: (document.getElementById('agent-form-style') as HTMLInputElement).value || null,
      languages: JSON.stringify(languages),
      isActive: (document.getElementById('agent-form-active') as HTMLInputElement).checked,
    };

    try {
      let res;
      if (id) {
        res = await fetch(`/api/agents/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
      } else {
        res = await fetch('/api/agents/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
      }

      if (res.ok) {
        closeAgentModal();
        await loadAgents();
      } else {
        const data = await res.json();
        alert('Save failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error');
    }
  });

  // Scheduler controls
  document.getElementById('btn-start-scheduler')?.addEventListener('click', async () => {
    const freq = (document.getElementById('agent-frequency') as HTMLInputElement).value;
    try {
      const res = await fetch('/api/agents/scheduler', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'start', frequencyHours: parseInt(freq) }),
      });
      const data = await res.json();
      alert(res.ok ? 'Scheduler started!' : `Error: ${data.error}`);
    } catch (err) {
      alert('Network error');
    }
  });

  document.getElementById('btn-stop-scheduler')?.addEventListener('click', async () => {
    try {
      const res = await fetch('/api/agents/scheduler', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'stop' }),
      });
      const data = await res.json();
      alert(res.ok ? 'Scheduler stopped.' : `Error: ${data.error}`);
    } catch (err) {
      alert('Network error');
    }
  });

  // Close agent modal
  document.getElementById('agent-modal-close')?.addEventListener('click', closeAgentModal);
  document.getElementById('agent-modal-cancel')?.addEventListener('click', closeAgentModal);
  document.getElementById('agent-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeAgentModal();
  });

  // Init
  loadComments();
</script>
