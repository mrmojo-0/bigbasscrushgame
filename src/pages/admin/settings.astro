---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Settings" currentPage="settings">
  <div class="space-y-6">
    <!-- API Configuration -->
    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-4">API Configuration</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">OpenRouter API Key</label>
          <div class="flex gap-2">
            <div class="relative flex-1">
              <input type="password" id="api-key" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none pr-20" placeholder="sk-or-..." />
              <button id="btn-toggle-key" type="button" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400 hover:text-white transition-colors px-2 py-1">
                Show
              </button>
            </div>
            <button id="btn-save-key" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
              Save Key
            </button>
          </div>
          <p id="key-status" class="text-xs text-gray-500 mt-1.5">Loading current key status...</p>
        </div>

        <div>
          <label class="block text-sm text-gray-400 mb-1.5">AI Model ID</label>
          <div class="flex gap-2">
            <input type="text" id="model-id" class="flex-1 bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" placeholder="x-ai/grok-4.1-fast" />
            <button id="btn-save-model" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
              Save
            </button>
          </div>
          <p class="text-xs text-gray-500 mt-1.5">OpenRouter model identifier used for AI content generation.</p>
        </div>
      </div>
    </div>

    <!-- Comment Generation -->
    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-4">Comment Generation</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Generation Interval (hours)</label>
          <div class="flex gap-2">
            <input type="number" id="comment-interval" min="1" max="168" value="4" class="flex-1 bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
            <button id="btn-save-interval" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
              Save
            </button>
          </div>
          <p class="text-xs text-gray-500 mt-1.5">How often AI agents generate new comments.</p>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Scheduler Status</label>
          <div class="flex items-center gap-3 mt-1">
            <span id="scheduler-status" class="px-3 py-1.5 rounded-full text-xs font-medium bg-gray-600/20 text-gray-400">Unknown</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Change Password -->
    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-4">Change Password</h2>
      <form id="password-form" class="space-y-4 max-w-md">
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Current Password</label>
          <input type="password" id="current-password" required class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">New Password</label>
          <input type="password" id="new-password" required minlength="6" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Confirm New Password</label>
          <input type="password" id="confirm-password" required minlength="6" class="w-full bg-ocean-900 border border-ocean-600 rounded-lg px-4 py-2.5 text-white text-sm focus:border-accent-500 outline-none" />
        </div>
        <div id="password-msg" class="hidden text-sm rounded-lg px-4 py-2.5"></div>
        <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
          Change Password
        </button>
      </form>
    </div>

    <!-- Site Build -->
    <div class="bg-ocean-800/50 border border-ocean-600/20 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-4">Site Build</h2>
      <div class="flex flex-wrap items-center gap-4">
        <button id="btn-rebuild" class="bg-crash-red hover:bg-red-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
          Rebuild Site
        </button>
        <div id="build-status-container" class="hidden flex items-center gap-3">
          <div id="build-spinner" class="w-4 h-4 border-2 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
          <span id="build-status-text" class="text-sm text-gray-300"></span>
        </div>
      </div>
      <p class="text-xs text-gray-500 mt-3">Triggers a full site rebuild to apply content, casino, and expert changes to all pages.</p>

      <!-- Build Log -->
      <div id="build-log" class="hidden mt-4 bg-ocean-900 rounded-lg p-4 max-h-48 overflow-y-auto">
        <pre id="build-log-content" class="text-xs text-gray-400 font-mono whitespace-pre-wrap"></pre>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // ============ LOAD SETTINGS ============
  async function loadSettings() {
    try {
      const res = await fetch('/api/settings/');
      if (res.ok) {
        const data = await res.json();
        const settings = data.settings || {};

        // API Key display
        const apiKey = settings.openrouter_api_key || settings.OPENROUTER_API_KEY || '';
        if (apiKey) {
          const masked = apiKey.length > 8
            ? '***' + apiKey.slice(-8)
            : '***';
          document.getElementById('key-status')!.textContent = `Current key: ${masked}`;
        } else {
          document.getElementById('key-status')!.textContent = 'No API key set.';
        }

        // Model
        const model = settings.ai_model || settings.AI_MODEL || '';
        if (model) {
          (document.getElementById('model-id') as HTMLInputElement).value = model;
        }

        // Comment interval
        const interval = settings.comment_interval || settings.COMMENT_INTERVAL || '4';
        (document.getElementById('comment-interval') as HTMLInputElement).value = interval;

        // Scheduler status
        const schedulerActive = settings.scheduler_active === 'true' || settings.SCHEDULER_ACTIVE === 'true';
        const statusEl = document.getElementById('scheduler-status')!;
        if (schedulerActive) {
          statusEl.textContent = 'Running';
          statusEl.className = 'px-3 py-1.5 rounded-full text-xs font-medium bg-accent-500/20 text-accent-400';
        } else {
          statusEl.textContent = 'Stopped';
          statusEl.className = 'px-3 py-1.5 rounded-full text-xs font-medium bg-gray-600/20 text-gray-400';
        }
      }
    } catch (err) {
      document.getElementById('key-status')!.textContent = 'Failed to load settings.';
    }
  }

  // ============ SAVE API KEY ============
  document.getElementById('btn-save-key')?.addEventListener('click', async () => {
    const key = (document.getElementById('api-key') as HTMLInputElement).value;
    if (!key.trim()) {
      alert('Please enter an API key.');
      return;
    }

    try {
      const res = await fetch('/api/settings/', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'openrouter_api_key', value: key }),
      });

      if (res.ok) {
        (document.getElementById('api-key') as HTMLInputElement).value = '';
        await loadSettings();
        alert('API key saved successfully.');
      } else {
        const data = await res.json();
        alert('Failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error.');
    }
  });

  // Toggle key visibility
  let keyVisible = false;
  document.getElementById('btn-toggle-key')?.addEventListener('click', () => {
    const input = document.getElementById('api-key') as HTMLInputElement;
    const btn = document.getElementById('btn-toggle-key')!;
    keyVisible = !keyVisible;
    input.type = keyVisible ? 'text' : 'password';
    btn.textContent = keyVisible ? 'Hide' : 'Show';
  });

  // ============ SAVE MODEL ============
  document.getElementById('btn-save-model')?.addEventListener('click', async () => {
    const model = (document.getElementById('model-id') as HTMLInputElement).value.trim();
    if (!model) {
      alert('Please enter a model ID.');
      return;
    }

    try {
      const res = await fetch('/api/settings/', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'ai_model', value: model }),
      });

      if (res.ok) {
        alert('Model saved successfully.');
      } else {
        const data = await res.json();
        alert('Failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error.');
    }
  });

  // ============ SAVE INTERVAL ============
  document.getElementById('btn-save-interval')?.addEventListener('click', async () => {
    const interval = (document.getElementById('comment-interval') as HTMLInputElement).value;

    try {
      const res = await fetch('/api/settings/', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'comment_interval', value: interval }),
      });

      if (res.ok) {
        alert('Interval saved.');
      } else {
        const data = await res.json();
        alert('Failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Network error.');
    }
  });

  // ============ CHANGE PASSWORD ============
  document.getElementById('password-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msgEl = document.getElementById('password-msg')!;

    const currentPw = (document.getElementById('current-password') as HTMLInputElement).value;
    const newPw = (document.getElementById('new-password') as HTMLInputElement).value;
    const confirmPw = (document.getElementById('confirm-password') as HTMLInputElement).value;

    if (newPw !== confirmPw) {
      msgEl.className = 'text-sm rounded-lg px-4 py-2.5 bg-crash-red/10 text-crash-red border border-crash-red/30';
      msgEl.textContent = 'New passwords do not match.';
      msgEl.classList.remove('hidden');
      return;
    }

    if (newPw.length < 6) {
      msgEl.className = 'text-sm rounded-lg px-4 py-2.5 bg-crash-red/10 text-crash-red border border-crash-red/30';
      msgEl.textContent = 'New password must be at least 6 characters.';
      msgEl.classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch('/api/settings/password', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword: currentPw, newPassword: newPw }),
      });

      if (res.ok) {
        msgEl.className = 'text-sm rounded-lg px-4 py-2.5 bg-accent-500/10 text-accent-400 border border-accent-500/30';
        msgEl.textContent = 'Password changed successfully!';
        msgEl.classList.remove('hidden');
        (document.getElementById('password-form') as HTMLFormElement).reset();
      } else {
        const data = await res.json();
        msgEl.className = 'text-sm rounded-lg px-4 py-2.5 bg-crash-red/10 text-crash-red border border-crash-red/30';
        msgEl.textContent = data.error || 'Failed to change password.';
        msgEl.classList.remove('hidden');
      }
    } catch (err) {
      msgEl.className = 'text-sm rounded-lg px-4 py-2.5 bg-crash-red/10 text-crash-red border border-crash-red/30';
      msgEl.textContent = 'Network error.';
      msgEl.classList.remove('hidden');
    }
  });

  // ============ REBUILD SITE ============
  document.getElementById('btn-rebuild')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-rebuild') as HTMLButtonElement;
    const statusContainer = document.getElementById('build-status-container')!;
    const statusText = document.getElementById('build-status-text')!;
    const buildLog = document.getElementById('build-log')!;
    const buildLogContent = document.getElementById('build-log-content')!;

    btn.disabled = true;
    btn.textContent = 'Building...';
    statusContainer.classList.remove('hidden');
    statusText.textContent = 'Triggering site rebuild...';
    buildLog.classList.remove('hidden');
    buildLogContent.textContent = 'Starting build process...\n';

    try {
      const res = await fetch('/api/build/trigger', { method: 'POST' });
      const data = await res.json();

      if (res.ok) {
        statusText.textContent = 'Build triggered successfully!';
        document.getElementById('build-spinner')?.classList.add('hidden');
        buildLogContent.textContent += `Build completed.\n${data.message || ''}`;
      } else {
        statusText.textContent = `Build failed: ${data.error || 'Unknown error'}`;
        document.getElementById('build-spinner')?.classList.add('hidden');
        buildLogContent.textContent += `Error: ${data.error || 'Unknown error'}\n`;
      }
    } catch (err) {
      statusText.textContent = 'Error triggering build.';
      document.getElementById('build-spinner')?.classList.add('hidden');
      buildLogContent.textContent += 'Network error during build trigger.\n';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Rebuild Site';
    }
  });

  // Init
  loadSettings();
</script>
