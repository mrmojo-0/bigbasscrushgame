---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
  target?: string;
  rel?: string;
  id?: string;
  fullWidth?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  target,
  rel,
  id,
  fullWidth = false,
} = Astro.props;

const Tag = href ? 'a' : 'button';

const baseClasses = 'inline-flex items-center justify-center gap-2 font-semibold rounded-xl transition-all duration-200 cursor-pointer';

const variantClasses = {
  primary: 'bg-gradient-cta text-white shadow-glow-green hover:shadow-[0_0_30px_rgba(34,197,94,0.5)] hover:scale-[1.02] active:scale-[0.98]',
  secondary: 'bg-ocean-700 text-white hover:bg-ocean-600 border border-ocean-500/30',
  outline: 'border-2 border-accent-500 text-accent-400 hover:bg-accent-500/10',
  ghost: 'text-gray-300 hover:text-white hover:bg-ocean-700/50',
};

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3 text-base',
  xl: 'px-10 py-4 text-lg',
};
---

<Tag
  href={href}
  target={target}
  rel={rel}
  id={id}
  class:list={[
    baseClasses,
    variantClasses[variant],
    sizeClasses[size],
    fullWidth && 'w-full',
    className,
  ]}
>
  <slot />
</Tag>
