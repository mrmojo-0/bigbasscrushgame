---
import { t, type TranslationKey } from '@i18n/utils';
import type { Locale } from '@i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const images = Array.from({ length: 14 }, (_, i) => ({
  src: `/images/game/theme-${i + 7}.jpg`,
  webp: `/images/game/theme-${i + 7}.webp`,
  alt: `Big Bass Crash screenshot ${i + 7}`,
}));
---

<section class="bg-ocean-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-white mb-8 text-center">
      <span class="bg-gradient-to-r from-accent-400 to-water-300 bg-clip-text text-transparent">
        {t(locale, 'gallery.title' as TranslationKey)}
      </span>
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {images.map((img) => (
        <div class="rounded-xl overflow-hidden border border-ocean-600/20 hover:border-accent-500/30 transition-colors">
          <picture>
            <source srcset={img.webp} type="image/webp" />
            <img
              src={img.src}
              alt={img.alt}
              width="400"
              height="300"
              loading="lazy"
              decoding="async"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </picture>
        </div>
      ))}
    </div>
  </div>
</section>
