---
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface Props {
  type: 'best_choice' | 'new' | 'popular' | 'hot' | 'fast_payout' | string;
  locale: Locale;
  rank?: number;
}

const { type, locale, rank } = Astro.props;

const badgeConfig: Record<string, { bg: string; text: string; key: string }> = {
  best_choice: { bg: 'bg-accent-500', text: 'text-white', key: 'casino.bestChoice' },
  new: { bg: 'bg-water-500', text: 'text-white', key: 'casino.new' },
  popular: { bg: 'bg-gold-400', text: 'text-ocean-900', key: 'casino.popular' },
  hot: { bg: 'bg-crash-red', text: 'text-white', key: 'casino.hot' },
  fast_payout: { bg: 'bg-water-700', text: 'text-white', key: 'casino.fastPayout' },
};

const config = badgeConfig[type] || { bg: 'bg-ocean-600', text: 'text-white', key: type };
---

<span class:list={[
  'inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider',
  config.bg,
  config.text,
]}>
  {rank && <span>#{rank}</span>}
  {t(locale, config.key)}
</span>
