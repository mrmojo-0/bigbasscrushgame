---
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  faqs: FaqItem[];
  locale: Locale;
}

const { faqs, locale } = Astro.props;
---

{faqs.length > 0 && (
  <section class="py-8" id="faq">
    <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
      {t(locale, 'faq.title')}
    </h2>

    <div class="space-y-3">
      {faqs.map((faq, index) => (
        <details class="group bg-ocean-800/50 border border-ocean-600/20 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-white font-medium hover:bg-ocean-700/30 transition-colors list-none">
            <span class="pr-4">{faq.q}</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 pb-4 text-gray-300 text-sm leading-relaxed border-t border-ocean-600/20">
            <div class="pt-3" set:html={faq.a} />
          </div>
        </details>
      ))}
    </div>
  </section>
)}
