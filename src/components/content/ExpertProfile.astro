---
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface Expert {
  name: string;
  avatarPath: string | null;
  title: string | null;
  bio: string;
  credentials: string | null;
}

interface Props {
  expert: Expert;
  locale: Locale;
  updatedDate?: string;
}

const { expert, locale, updatedDate } = Astro.props;
const credentials: string[] = expert.credentials ? JSON.parse(expert.credentials) : [];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: expert.name,
  jobTitle: expert.title || 'iGaming Expert',
  description: expert.bio,
};
---

<div class="bg-glass backdrop-blur-sm border border-ocean-600/30 rounded-2xl p-6 mb-8" itemscope itemtype="https://schema.org/Person">
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <div class="flex flex-col sm:flex-row items-start gap-5">
    <!-- Avatar -->
    <div class="flex-shrink-0">
      <div class="w-20 h-20 rounded-2xl bg-ocean-700 border-2 border-accent-500/30 overflow-hidden">
        {expert.avatarPath ? (
          <img src={expert.avatarPath} alt={expert.name} class="w-full h-full object-cover" loading="lazy" width="80" height="80" />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-2xl font-bold text-accent-400">
            {expert.name.charAt(0)}
          </div>
        )}
      </div>
    </div>

    <!-- Info -->
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="text-lg font-bold text-white" itemprop="name">{expert.name}</h3>
        <!-- Verified badge -->
        <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
      </div>

      {expert.title && (
        <p class="text-sm text-accent-400 font-medium mb-2" itemprop="jobTitle">{expert.title}</p>
      )}

      <p class="text-sm text-gray-300 leading-relaxed mb-3" itemprop="description">{expert.bio}</p>

      {/* Credentials */}
      {credentials.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {credentials.map(cred => (
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-ocean-700 text-xs text-gray-300 border border-ocean-600/30">
              <svg class="w-3 h-3 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {cred}
            </span>
          ))}
        </div>
      )}

      {updatedDate && (
        <p class="text-xs text-gray-500 mt-3">
          {t(locale, 'review.updatedOn')}: {updatedDate}
        </p>
      )}
    </div>
  </div>
</div>
