---
import CasinoCard from './CasinoCard.astro';
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface Casino {
  id: number;
  name: string;
  slug: string;
  brandId: string;
  logoPath: string | null;
  rating: number | null;
  bonusAmount: string | null;
  welcomeBonus: string | null;
  freeSpins: string | null;
  minDeposit: string | null;
  license: string | null;
  paymentMethods: string | null;
  pros: string | null;
  cons: string | null;
  badges: string | null;
  description: string | null;
}

interface Props {
  casinos: Casino[];
  locale: Locale;
  pageSlug: string;
  variant?: 'compact' | 'full';
  title?: string;
  maxItems?: number;
}

const { casinos, locale, pageSlug, variant = 'full', title, maxItems } = Astro.props;

const displayCasinos = maxItems ? casinos.slice(0, maxItems) : casinos;
const displayTitle = title || t(locale, 'casino.topCasinos');
---

<section class="py-8" id="top-casinos">
  <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
    <span class="bg-gradient-to-r from-accent-400 to-water-300 bg-clip-text text-transparent">
      {displayTitle}
    </span>
  </h2>

  <div class="grid grid-cols-1 gap-6">
    {displayCasinos.map((casino, index) => (
      <CasinoCard
        casino={casino}
        locale={locale}
        rank={index + 1}
        pageSlug={pageSlug}
        variant={variant}
      />
    ))}
  </div>
</section>
