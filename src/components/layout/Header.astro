---
import { LOCALES, type Locale, ALL_LOCALES } from '@i18n/config';
import { t, getNavLinks, getPagePath, type PageId } from '@i18n/utils';

interface Props {
  locale: Locale;
  currentPage: PageId;
}

const { locale, currentPage } = Astro.props;
const navLinks = getNavLinks(locale);
const localeInfo = LOCALES[locale];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-ocean-900/90 backdrop-blur-xl border-b border-ocean-600/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getPagePath('home', locale)} class="flex items-center gap-2 group">
        <img
          src="/images/game/logo.webp"
          alt="Big Bass Crash"
          width="32"
          height="32"
          class="w-8 h-8 rounded-lg group-hover:shadow-glow-green transition-shadow"
        />
        <span class="hidden sm:block text-lg font-bold bg-gradient-to-r from-accent-400 to-water-300 bg-clip-text text-transparent">
          BigBassCrash
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.path}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200',
              currentPage === link.pageId
                ? 'bg-accent-500/10 text-accent-400'
                : 'text-gray-300 hover:text-white hover:bg-ocean-700/50',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side: Language + CTA -->
      <div class="flex items-center gap-3">
        <!-- Language Selector -->
        <div class="relative group">
          <button
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-gray-300 hover:text-white hover:bg-ocean-700/50 transition-colors min-h-[48px] min-w-[48px]"
            aria-label="Select language"
          >
            <span class="text-base">{localeInfo.flag}</span>
            <span class="hidden sm:inline">{localeInfo.nativeName}</span>
            <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown -->
          <div class="absolute right-0 top-full mt-1 w-48 max-h-80 overflow-y-auto bg-ocean-800 border border-ocean-600/50 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {ALL_LOCALES.map(loc => (
              <a
                href={getPagePath(currentPage, loc)}
                class:list={[
                  'flex items-center gap-2 px-3 py-2 text-sm hover:bg-ocean-700/50 transition-colors first:rounded-t-xl last:rounded-b-xl min-h-[44px]',
                  loc === locale ? 'text-accent-400 bg-accent-500/5' : 'text-gray-300',
                ]}
              >
                <span>{LOCALES[loc].flag}</span>
                <span>{LOCALES[loc].nativeName}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-3 rounded-lg text-gray-300 hover:text-white hover:bg-ocean-700/50 transition-colors"
          aria-label="Menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-1">
        {navLinks.map(link => (
          <a
            href={link.path}
            class:list={[
              'px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
              currentPage === link.pageId
                ? 'bg-accent-500/10 text-accent-400'
                : 'text-gray-300 hover:text-white hover:bg-ocean-700/50',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
