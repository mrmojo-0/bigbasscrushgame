---
import type { Locale } from '@i18n/config';
import { t, getPagePath } from '@i18n/utils';

interface BreadcrumbItem {
  label: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
  locale: Locale;
}

const { items, locale } = Astro.props;
const siteUrl = 'https://bigbasscrashgame.com';

// Build schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': items.map((item, i) => ({
    '@type': 'ListItem',
    'position': i + 1,
    'name': item.label,
    ...(item.url ? { 'item': `${siteUrl}${item.url}` } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="mb-6">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-400">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && (
          <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.url ? (
          <a href={item.url} class="hover:text-accent-400 transition-colors">{item.label}</a>
        ) : (
          <span class="text-gray-300">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
