---
import { LOCALES, type Locale, isRtl } from '@i18n/config';
import { getAlternateUrls, t, type PageId } from '@i18n/utils';

interface Props {
  locale: Locale;
  pageId: PageId;
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalPath?: string;
  schema?: object[];
  noindex?: boolean;
}

const {
  locale,
  pageId,
  title,
  description,
  ogImage = '/images/og/default.jpg',
  ogType = 'website',
  canonicalPath,
  schema = [],
  noindex = false,
} = Astro.props;

const dir = isRtl(locale) ? 'rtl' : 'ltr';
const langCode = locale === 'zh' ? 'zh-CN' : locale;
const siteUrl = 'https://bigbasscrashgame.com';
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : `${siteUrl}${Astro.url.pathname}`;
const alternateUrls = getAlternateUrls(pageId, siteUrl);
---

<!doctype html>
<html lang={langCode} dir={dir} class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Canonical & Hreflang -->
  <link rel="canonical" href={canonicalUrl} />
  {alternateUrls.map(({ locale: altLocale, url }) => (
    <link rel="alternate" hreflang={altLocale === 'zh' ? 'zh-CN' : altLocale} href={url} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Big Bass Crash Game" />
  <meta property="og:locale" content={langCode} />
  {alternateUrls
    .filter(({ locale: alt }) => alt !== locale)
    .slice(0, 10)
    .map(({ locale: alt }) => (
      <meta property="og:locale:alternate" content={alt === 'zh' ? 'zh_CN' : alt} />
    ))
  }

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Schema Markup -->
  {schema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <style is:global>
    * {
      box-sizing: border-box;
    }
    body {
      background-color: #0a1628;
      color: #f8fafc;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      margin: 0;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    ::selection {
      background: rgba(34, 197, 94, 0.3);
      color: #fff;
    }
    /* Scrollbar styling */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #0a1628;
    }
    ::-webkit-scrollbar-thumb {
      background: #1e3a5f;
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #2a4a73;
    }
    /* RTL adjustments */
    [dir="rtl"] {
      text-align: right;
    }
  </style>
</head>
<body class="bg-ocean-900 text-white antialiased">
  <slot />
</body>
</html>
