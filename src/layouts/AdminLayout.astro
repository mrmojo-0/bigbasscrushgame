---
interface Props {
  title: string;
  currentPage?: string;
}

const { title, currentPage = '' } = Astro.props;

const navItems = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin/', icon: '📊' },
  { id: 'casinos', label: 'Casinos', href: '/admin/casinos', icon: '🎰' },
  { id: 'content', label: 'Content', href: '/admin/content', icon: '📝' },
  { id: 'comments', label: 'Comments & Agents', href: '/admin/comments', icon: '💬' },
  { id: 'experts', label: 'Experts', href: '/admin/experts', icon: '👤' },
  { id: 'images', label: 'Images', href: '/admin/images', icon: '🖼️' },
  { id: 'settings', label: 'Settings', href: '/admin/settings', icon: '⚙️' },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    * { box-sizing: border-box; }
    body {
      background-color: #0a1628;
      color: #f8fafc;
      font-family: 'Inter', system-ui, sans-serif;
      margin: 0;
    }
  </style>
</head>
<body class="bg-ocean-900 text-white min-h-screen">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-ocean-950 border-r border-ocean-600/20 flex-shrink-0 hidden md:flex flex-col">
      <div class="p-5 border-b border-ocean-600/20">
        <a href="/admin/" class="flex items-center gap-2">
          <div class="w-8 h-8 bg-gradient-cta rounded-lg flex items-center justify-center text-white font-bold text-sm">
            BB
          </div>
          <span class="text-sm font-bold text-white">Admin Panel</span>
        </a>
      </div>

      <nav class="flex-1 p-3 space-y-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors',
              currentPage === item.id
                ? 'bg-accent-500/10 text-accent-400 font-medium'
                : 'text-gray-400 hover:text-white hover:bg-ocean-800',
            ]}
          >
            <span>{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <div class="p-3 border-t border-ocean-600/20">
        <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-ocean-800 transition-colors">
          <span>🌐</span>
          <span>View Site</span>
        </a>
        <button
          id="logout-btn"
          class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-400 hover:text-crash-red hover:bg-ocean-800 transition-colors w-full text-left"
        >
          <span>🚪</span>
          <span>Logout</span>
        </button>
      </div>
    </aside>

    <!-- Mobile header -->
    <div class="md:hidden fixed top-0 left-0 right-0 z-50 bg-ocean-950 border-b border-ocean-600/20 p-3 flex items-center justify-between">
      <a href="/admin/" class="flex items-center gap-2">
        <div class="w-7 h-7 bg-gradient-cta rounded-lg flex items-center justify-center text-white font-bold text-xs">BB</div>
        <span class="text-sm font-bold">Admin</span>
      </a>
      <button id="mobile-nav-btn" class="p-2 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Main content -->
    <main class="flex-1 min-w-0">
      <div class="md:hidden h-14"></div>
      <div class="p-6 md:p-8 max-w-7xl mx-auto">
        <h1 class="text-2xl font-bold text-white mb-6">{title}</h1>
        <slot />
      </div>
    </main>
  </div>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/admin/login';
    });
  </script>
</body>
</html>
