    "@tailwindcss/typography": "^0.5.19",
    "astro": "^5.17.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "marked": "^17.0.3",
    "preact": "^10.28.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
